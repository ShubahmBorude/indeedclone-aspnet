@* _IndeedCloneHomePageNavbarLayout *@
@using IndeedClone.ThirdParty.EncDec
@inject IConfiguration Configuration
@{
    var logoUrl = Configuration["Branding:Logo"];
    
 // # Auth state (RefNo is your real auth indicator)
    bool isLogin = !string.IsNullOrEmpty(User.FindFirst("RefNo")?.Value);
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;

 // # User data
    string? rawUserName = User.Identity?.Name;
    string displayUserName = string.IsNullOrWhiteSpace(rawUserName) ? "Guest User" : rawUserName;
    string userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "No email available";

 // # Avatar
    string? picture = User.FindFirst("Picture")?.Value;
    string avatarLetter = "U";

    if (isAuthenticated && !string.IsNullOrWhiteSpace(rawUserName))
        avatarLetter = rawUserName.Trim().Substring(0, 1).ToUpper();
    

 // # Get current controller and action for active link detection
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    
 // # Helper function to check if link is active
    bool IsActive(string controller, string action = null)
    {
        if (action == null)
            return currentController == controller;

        return currentController == controller && currentAction == action;
    }

}

 


<!DOCTYPE html>
<html>

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0">

    <!-- Bootstrap-5 and custom CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">

    <!-- custom css -->
    <link rel="stylesheet" href="~/css/app-home/indeedhomenavabrlayout.css">

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <style> body{ padding : 0 !important} </style>

</head>

<body>



   <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light">
        <div class="container-fluid">
            <!-- Brand/Logo -->
            <a class="navbar-brand me-3" href="@Url.Action("Retrieve", "IndeedClone")">
                <div class="d-flex align-items-center">
                    <img src="@logoUrl" alt="Logo" style="height: 30px;">
                    <div class="mt-1" style="font-size:2.1rem; font-family:'Arial Rounded MT Bold', 'Nunito', sans-serif;color: #0A4299; font-weight: bold; letter-spacing: -2px !important;">clone</div> 
                </div>
            </a>
            
            <!-- Desktop Navigation -->
            <div class="collapse navbar-collapse" id="navbarContent">
                <!-- Left Navigation Links -->
                <ul class="navbar-nav me-auto mb-2 mt-3 mb-lg-0">
                    <li class="nav-item me-1">
                        <a class="nav-link @(IsActive("IndeedClone", "Retrieve") ? "active" : "")" aria-current="page" href="@Url.Action("Retrieve", "IndeedClone")">Home</a>
                    </li>
                    <li class="nav-item me-1">
                        <a class="nav-link @(IsActive("IndeedClone", "CompanyReviews") ? "active" : "")" href="@Url.Action("CompanyReviews", "IndeedClone")">Company Reviews</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("IndeedClone", "Salaries") ? "active" : "")" href="@Url.Action("Salaries", "IndeedClone")">Salaries</a>
                    </li>
                </ul>
                
                <!-- Right Side Items -->
                <div class="d-flex flex-row align-items-center">

                    <!-- Sign In Section -->
                    @if(!isLogin)
                    {
                    <ul class="navbar-nav mb-2 mb-lg-0 me-3">
                        <li class="nav-item d-flex align-items-center">
                            <a class="nav-link px-2 mt-3" href="@Url.Action("Login", "Auth")" style="color: #2557a7; font-weight: 700;">Sign in</a>
                        </li>
                    </ul>
                    }
                    else
                    {
                    <ul class="navbar-nav mb-2 mb-lg-0 me-3">
                        <li class="nav-item d-flex align-items-center">
                            <a class="nav-link px-2 mt-3" href="@Url.Action("Retrieve", "JobDashboard")" style="color: #2557a7; font-weight: 700;">
                                Job Dashboard
                            </a>
                        </li>
                    </ul>

                    <div class="vertical-separator me-3"></div>
                    }

                    @if(!isLogin)
                    {
                    <!-- Vertical separator -->
                    <div class="vertical-separator me-3"></div>
                    }


                    <!-- Icons Section -->
                   @if(isLogin)
                   {
                    <ul class="navbar-nav mb-2 mb-lg-0 me-3 mt-3">
                        <!-- Chat Icon -->
                        <li class="nav-item me-3">
                            <a class="nav-link" href="#">
                                <i class="bi bi-chat-left-text-fill"></i>
                            </a>
                        </li>
                        
                        <!-- Notifications Dropdown -->
                        <li class="nav-item dropdown me-3">
                            <a class="nav-link position-relative" href="#" id="notificationDropdown" role="button" 
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-bell-fill"></i>
                                <span class="notification-badge bg-danger">3</span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end" 
                                 aria-labelledby="notificationDropdown" style="min-width: 300px;">
                                <div class="p-3 border-bottom">
                                    <h5 class="mb-0">Notifications</h5>
                                </div>
                                <div class="p-3 border-bottom">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            <div style="width: 32px; height: 32px; background-color: #007bff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white;">J</div>
                                        </div>
                                        <div>
                                            <h6 class="mb-1">New Job Posting</h6>
                                            <small class="text-muted">1 hour ago</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </li>
                        
                        <!-- Account Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link" href="#" id="accountDropdown" role="button" 
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-fill"></i>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end" 
                                 aria-labelledby="accountDropdown" style="min-width: 250px;">
                                <div class="p-3">
                                    <div class="d-flex align-items-center">
                                        <div class="me-0">
                                    @if (isLogin && !string.IsNullOrEmpty(picture))
                                    {
                                      <img src="@picture" class="user-avatar rounded-circle" alt="User Avatar" />

                                    }else
                                    {
                                        <div class="user-avatar"> @avatarLetter </div>
                                    }
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold">@displayUserName</h6>
                                            <small class="text-muted">@userEmail</small>
                                        </div>
                                    </div>
                                </div>
                                <hr class="my-0">
                                <a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i>Profile & Account</a>
                                <a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2"></i>Settings</a>
                                @* <hr class="my-0"> *@

                               @if(isLogin)
                               {
                                <form method="post" action="@Url.Action("Logout", "Auth")" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item py-2 btn w-100">
                                    <i class="bi bi-box-arrow-right me-2"></i>Sign out
                                </button>
                                </form>
                               }
                               else
                               {
                                <a class="dropdown-item py-2" href="@Url.Action("Login", "Auth")"><i class="bi bi-person-circle me-2"></i>Sign In</a>
                               }
                            </div>
                        </li>
                    </ul>
                   }
                    
                   <!-- Vertical separator -->
                   @if(isLogin)
                   {
                     <div class="vertical-separator me-3"></div>
                   }
                    
                    <!-- Employers/Post Job Link -->
                    <ul class="navbar-nav mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link px-2 mt-3" href="@Url.Action("Retrieve", "JobPost")" style="color: #333; font-weight: 500;">
                                Employers / Post Job
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
            
            <!-- Mobile Menu Toggle -->
            <button class="mobile-menu-toggle" id="mobileMenuToggle">
                <i class="bi bi-list"></i>
            </button>
        </div>
    </nav>
    
    <!-- Mobile Sidebar -->
    <div class="mobile-sidebar" id="mobileSidebar">
        <div class="sidebar-header">
            <h4 style="color: #2557a7; font-weight: 700;"></h4>
            <button type="button" class="btn-close" id="closeSidebar" data-bs-dismiss="alert" aria-label="Close"></button>

        </div>
        
        <!-- User Info (Logged In) -->
        <div class="user-info-sidebar">
            @if (isLogin && !string.IsNullOrEmpty(picture))
            {
              <img src="@picture" class="user-avatar rounded-circle" alt="User Avatar" />
            }else
            {
                <div class="user-avatar"> @avatarLetter </div>
            }
            <div class="user-details">
                <h5>@displayUserName</h5>
                <p>@userEmail</p>
            </div>
        </div>
        
        <!-- Main Navigation -->
        <div class="sidebar-section">
            <h6 class="sidebar-section-title">Navigation</h6>
            <ul class="sidebar-nav">
                <li class="sidebar-nav-item">
                    <a href="@Url.Action("Retrieve", "IndeedClone")" class="sidebar-nav-link @(IsActive("IndeedClone", "Retrieve") ? "active" : "")">
                        <span class="sidebar-nav-icon"><i class="bi bi-house-door"></i></span>
                        Home
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a href="@Url.Action("CompanyReviews", "IndeedClone")" class="sidebar-nav-link @(IsActive("IndeedClone", "CompanyReviews") ? "active" : "")">
                        <span class="sidebar-nav-icon"><i class="bi bi-building"></i></span>
                        Company Reviews
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a href="@Url.Action("Salaries", "IndeedClone")" class="sidebar-nav-link @(IsActive("IndeedClone", "Salaries") ? "active" : "")">
                        <span class="sidebar-nav-icon"><i class="bi bi-cash-stack"></i></span>
                        Salaries
                    </a>
                </li>
                <li class="sidebar-nav-item">
                     <a href="@Url.Action("Retrieve", "JobDashboard")" class="sidebar-nav-link @(IsActive("JobDashboard", "Retrieve") ? "active" : "")">
                         <span class="sidebar-nav-icon"><i class="bi bi-speedometer2"></i></span>
                         Job Dashboard
                     </a>
                </li>
            </ul>
        </div>
        
        <!-- Account Section -->
        <div class="sidebar-section">
            <h6 class="sidebar-section-title">Account</h6>
            <ul class="sidebar-nav">
                <li class="sidebar-nav-item">
                    <a href="#" class="sidebar-nav-link">
                        <span class="sidebar-nav-icon"><i class="bi bi-chat-left-text"></i></span>
                        Messages
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a href="#" class="sidebar-nav-link">
                        <span class="sidebar-nav-icon"><i class="bi bi-bell"></i></span>
                        Notifications
                        <span class="badge bg-danger ms-auto">3</span>
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a href="#" class="sidebar-nav-link">
                        <span class="sidebar-nav-icon"><i class="bi bi-person"></i></span>
                        Profile & Account
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a href="#" class="sidebar-nav-link">
                        <span class="sidebar-nav-icon"><i class="bi bi-gear"></i></span>
                        Settings
                    </a>
                </li>
            </ul>
        </div>
        
        <!-- Employers Section -->
        <div class="sidebar-section">
            <h6 class="sidebar-section-title">For Employers</h6>
            <ul class="sidebar-nav">
                <li class="sidebar-nav-item">
                    <a href="@Url.Action("Retrieve", "JobPost")" class="sidebar-nav-link" style="color: #333; font-weight: 500;">
                        <span class="sidebar-nav-icon"><i class="bi bi-briefcase"></i></span>
                        Employers / Post Job
                    </a>
                </li>
            </ul>
        </div>
        
        <!-- Sign In/Out Section -->
        <div class="sidebar-section mt-4">
            @if (!isLogin)
            {
                <a href="@Url.Action("Login", "Auth")"
                   class="btn btn-outline-primary w-100 mb-2"
                   style="color: #2557a7; font-weight: 700;">
                    Sign in
                </a>
            }
            else
            {
                <form method="post" action="@Url.Action("Logout", "Auth")" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-primary w-100 mb-2">
                        Sign out
                    </button>
                </form>
            }
        </div>
    </div>
    
    <!-- Sidebar Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
              
                   @RenderBody()   
                   

  <script>
        // Mobile sidebar functionality
        document.addEventListener('DOMContentLoaded', function() {
            const mobileMenuToggle = document.getElementById('mobileMenuToggle');
            const closeSidebar = document.getElementById('closeSidebar');
            const mobileSidebar = document.getElementById('mobileSidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            
            // Open sidebar
            mobileMenuToggle.addEventListener('click', function() {
                mobileSidebar.classList.add('active');
                sidebarOverlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            });
            
            // Close sidebar
            function closeMobileSidebar() {
                mobileSidebar.classList.remove('active');
                sidebarOverlay.classList.remove('active');
                document.body.style.overflow = '';
            }
            
            closeSidebar.addEventListener('click', closeMobileSidebar);
            sidebarOverlay.addEventListener('click', closeMobileSidebar);
            
            // Close sidebar when clicking outside on mobile
            document.addEventListener('click', function(event) {
                if (window.innerWidth <= 992 && 
                    !mobileSidebar.contains(event.target) && 
                    !mobileMenuToggle.contains(event.target) &&
                    mobileSidebar.classList.contains('active')) {
                    closeMobileSidebar();
                }
            });
            
            // Close sidebar on escape key
            document.addEventListener('keydown', function(event) {
                if (event.key === 'Escape' && mobileSidebar.classList.contains('active')) {
                    closeMobileSidebar();
                }
            });
        });
 </script>
 
</body>
</html>