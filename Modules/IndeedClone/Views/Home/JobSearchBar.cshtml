@model IndeedClone.Modules.IndeedClone.DTO.IndeedCloneJobSearchFilterDTO
@{

 }

 <!DOCTYPE html>
 <html>

 <head>

    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0">

    <!-- Fav Icon -->
    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"] - IndeedClone for Employer</title>


    <!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">
    
    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

     <!-- custom css -->
    <link rel="stylesheet" href="~/css/app-home/indeedhomenavabrlayout.css">
    <link rel="stylesheet" href="~/css/app-home/jobsearch.css">

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <!-- jquery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- ionicons -->
    <script type="module" src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.js"></script>

 </head>

 <body>

 <form action="@Url.Action("Retrieve", "IndeedClone")" method="get">
    <div class="job-search-input mx-auto col-md-10 col-lg-8 col-xl-7 px-3">
        <div class="input-group bg-white p-0" style="
            border-radius: 8px; 
            border: 1px solid #cccccc;
            box-shadow: none;
        ">
            <!-- Job Search Autocomplete -->
            <div class="position-relative flex-grow-1">
                <span class="input-group-text bg-transparent border-0 position-absolute start-0 top-50 translate-middle-y ps-3 z-index-1">
                    <ion-icon name="search" style="width: 16px; height: 16px; color: #888888;"></ion-icon>
                </span>
                <input type="text"
                    class="form-control border-0 mt-1 py-2 ps-5 pe-3"
                    id="jobSearch"
                    name="Keyword"
                    value="@Model?.Keyword"
                    placeholder="Job title or keywords"
                    autocomplete="off"
                    aria-autocomplete="list"
                    style="height: 44px; font-size: 15px; background-color: white; border-radius: 8px 0 0 8px !important;">
                <div class="autocomplete-dropdown" id="jobSuggestions"></div>
            </div>

            <div class="vertical-separator" style="width: 1px; height: 28px; background-color: #e0e0e0; align-self: center;"></div>

            <!-- Location Autocomplete -->
            <div class="position-relative flex-grow-1">
                <span class="input-group-text bg-transparent border-0 position-absolute start-0 top-50 translate-middle-y ps-3 z-index-1">
                    <ion-icon name="location-sharp" style="width: 16px; height: 16px; color: #888888;"></ion-icon>
                </span>
                <input type="text"
                    class="form-control border-0 mt-1 py-2 ps-5 pe-3"
                    id="locationSearch"
                    name="Location"
                    value="@Model?.Location"
                    placeholder="City or state"
                    autocomplete="off"
                    aria-autocomplete="list"
                    style="height: 44px; font-size: 15px; background-color: white;">
                <div class="autocomplete-dropdown" id="locationSuggestions"></div>
            </div>

            <!-- Hidden Input -->
            <input type="hidden" name="search_type">

            <div class="find-jobs p-2 pe-2">
                <button type="submit"
                    class="btn fw-bold px-4"
                    style="
                        height: 40px;
                        background-color: #255aa8;
                        color: white;
                        border: none;
                        border-radius: 5px;
                        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
                        transition: background-color 0.15s ease;
                        font-size: 15px;
                        letter-spacing: 0.3px;
                    "
                    onmouseover="this.style.backgroundColor='#1a4b8f'"
                    onmouseout="this.style.backgroundColor='#255aa8'">
                    Find Jobs
                </button>
            </div>
        </div>
    </div>
</form>


 </body>

</html>


