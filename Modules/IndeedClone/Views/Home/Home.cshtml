<script>
    function showJobDetails(JobUid) {
        if (!JobUid) return;
       
        localStorage.setItem("selectedJobUid", JobUid);
        const urlTemplate = '@Url.Action("FullJobDescription", "IndeedClone")';

        fetch(`${urlTemplate}?jobUid=${JobUid}`)
            .then(res => res.text())
            .then(html => {
                document.getElementById("jobDetailsColumn").innerHTML = html;
                highlightSelectedCard(JobUid);
            }) 
            .catch(() => alert("Failed to load job details"));
    }

    document.getElementById("jobDetailsColumn").scrollTop = 0;

   document.addEventListener("DOMContentLoaded", function () {
    const savedJobUid = localStorage.getItem("selectedJobUid");
    if (savedJobUid) {
        showJobDetails(savedJobUid);
    } else {
        const firstJobCard = document.querySelector(".indeed-job-card");
        if (firstJobCard) {
            firstJobCard.click();
        }
    }
});

    function highlightSelectedCard(JobUid) {

    document.querySelectorAll(".indeed-job-card").forEach(card => {
        card.classList.remove("active-job");
    });

    const selectedCard = document.querySelector(`[data-id="${JobUid}"]`);
    if (selectedCard) {
        selectedCard.classList.add("active-job");
    }
}
</script>

<script>
    let currentPage = @Model.Pagination.CurrentPage;
    let totalPages = @Model.Pagination.TotalPages;

    document.addEventListener('click', function(e) {
        const pageLink = e.target.closest('.page-link[data-page]');
        if (!pageLink) return;
        e.preventDefault();
        const page = parseInt(pageLink.dataset.page);
        if (isNaN(page) || page < 1 || page > totalPages || page === currentPage) return;
        loadJobsPage(page);
    });

    function loadJobsPage(page) {
        const jobCardsContainer = document.getElementById('jobCardsContainer');
        if (!jobCardsContainer) {
            console.error('jobCardsContainer not found!');
            return;
        }
        
        // Show loading state
        jobCardsContainer.style.opacity = '0.5';
        
        // Collect all current filters from the filter form
        const form = document.getElementById('filterForm');
        if (!form) {
            console.error('filterForm not found!');
            return;
        }
        
        const formData = new FormData(form);
        const params = new URLSearchParams(formData);
        params.append('page', page);
        
        const getJobPage = '@Url.Action("GetJobsPage", "IndeedClone")';
        
        fetch(`${getJobPage}?${params.toString()}`)
            .then(response => {
                if (!response.ok) {
                    throw new Error('Network response was not ok');
                }
                return response.json();
            })
            .then(jobs => {
                if (!jobs || jobs.length === 0) {
                    // Show empty state
                    jobCardsContainer.innerHTML = '<div class="no-jobs-message">No jobs found on this page</div>';
                    jobCardsContainer.style.opacity = '1';
                    
                    // Update current page
                    currentPage = page;
                    updatePaginationActiveState(page);
                    
                    // Show empty state in details column
                    document.getElementById("jobDetailsColumn").innerHTML = `
                        <div class="indeed-empty-state">
                            <div class="indeed-empty-icon">
                                <svg viewBox="0 0 24 24">
                                    <path d="M20 6h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zM10 4h4v2h-4V4zm10 16H4V10h16v10z"/>
                                </svg>
                            </div>
                            <h3 class="indeed-empty-title">No jobs on this page</h3>
                            <p class="indeed-empty-text">Try another page</p>
                        </div>
                    `;
                    return;
                }
                
                // Build HTML from JSON data
                let html = '';
                
                jobs.forEach(job => {
                    // Safely access properties with defaults
                    const supplementedPay = job.supplementedPay || [];
                    const employeeType = job.employeeType || [];
                    const benefits = job.benefits || [];
                    
                    const types = supplementedPay.slice(0, 1);
                    const remaining = employeeType.length - types.length;
                    const benefitItems = benefits.slice(0, 1);
                    const remainingBenefits = benefits.length - benefitItems.length;
                    
                    html += `
                        <div class="indeed-job-card" data-id="${job.jobUid || ''}" onclick="showJobDetails('${job.jobUid || ''}')">
                            
                            <!-- Header with Title and Menu -->
                            <div class="job-card-header">
                                <div class="job-title-wrapper">
                                    <h2 class="job-title">
                                        <a href="#" class="job-title-link" onclick="event.preventDefault();">
                                            <span title="${job.jobTitle || ''}">${job.jobTitle || ''}</span>
                                        </a>
                                    </h2>
                                </div>
                                
                                <!-- Indeed Three Dots Dropdown -->
                                <div class="dropdown job-menu-container" onclick="event.stopPropagation();">
                                    <button class="job-menu-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <svg class="job-menu-dots" viewBox="0 0 24 24">
                                            <circle cx="12" cy="6" r="2" fill="currentColor"/>
                                            <circle cx="12" cy="12" r="2" fill="currentColor"/>
                                            <circle cx="12" cy="18" r="2" fill="currentColor"/>
                                        </svg>
                                    </button>
                                    <ul class="indeed-dropdown-menu">
                                        <li>
                                            <a class="dropdown-item" href="#">
                                                <ion-icon name="bookmark-outline"></ion-icon>
                                                Save job
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" href="#">
                                                <ion-icon name="flag-outline"></ion-icon>
                                                Report job
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <!-- Company Name -->
                            <div class="company-name">${job.companyName || ''}</div>

                            <!-- Location -->
                            <div class="job-location">
                                <svg class="location-icon" viewBox="0 0 24 24">
                                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                                </svg>
                                <span style="color: #2c3e50;">${job.jobLocation || ''} - ${job.city || ''}, ${job.area || ''}</span>
                            </div>

                            <!-- Response Time -->
                            ${job.recruitmentTimeline ? `
                                <div class="response-badge">
                                    <svg class="response-icon" viewBox="0 0 24 24">
                                        <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/>
                                    </svg>
                                    Typically responds within ${job.recruitmentTimeline}
                                </div>
                            ` : ''}

                            <!-- Job Attributes -->
                            <div class="job-attributes">
                                <!-- Salary -->
                                <div class="attribute-item">
                                    <svg class="attribute-icon" viewBox="0 0 24 24">
                                        <path d="M12 2L2 7l10 5 10-5-10-5zm0 17L2 14v5l10 5 10-5v-5l-10 5z"/>
                                    </svg>
                                    <span class="salary-format">
                                        <span class="rupee-symbol">₹</span>${job.minimumPay || 0} - 
                                        <span class="rupee-symbol">₹</span>${job.maximumPay || 0} 
                                        <span style="color: #2c3e50; margin-left: 2px;">${job.payRateType || ''}</span>
                                    </span>
                                </div>

                                <!-- Employment Type -->
                                ${types.length > 0 ? `
                                    <div class="attribute-item">
                                        <svg class="attribute-icon" viewBox="0 0 24 24">
                                            <path d="M20 6h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-8 6c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm4-6h-8V4h8v2z"/>
                                        </svg>
                                        <span class="attribute-text">
                                            ${types.join(', ')}
                                            ${remaining > 0 ? `<span class="more-badge">+${remaining} more</span>` : ''}
                                        </span>
                                    </div>
                                ` : ''}

                                <!-- Benefits -->
                                ${benefitItems.length > 0 ? `
                                    <div class="attribute-item">
                                        <svg class="attribute-icon" viewBox="0 0 24 24">
                                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                                        </svg>
                                        <span class="attribute-text">
                                            ${benefitItems.join(', ')}
                                            ${remainingBenefits > 0 ? `<span class="more-badge">+${remainingBenefits} more</span>` : ''}
                                        </span>
                                    </div>
                                ` : ''}
                            </div>

                            <!-- Footer -->
                            <div class="job-card-footer">
                                <div class="easily-apply-badge">
                                    <svg class="apply-icon" viewBox="0 0 24 24">
                                        <path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1 0 1.71-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/>
                                    </svg>
                                    Easily apply
                                </div>
                                <span class="posted-date">${job.postedAgo || ''}</span>
                            </div>
                        </div>
                    `;
                });
                
                jobCardsContainer.innerHTML = html;
                jobCardsContainer.style.opacity = '1';
                currentPage = page;
                updatePaginationActiveState(page);
                localStorage.removeItem("selectedJobUid");
                requestAnimationFrame(() => {
                const firstJobCard = document.querySelector(".indeed-job-card");
                if (firstJobCard) {
                    firstJobCard.click();
                }
            });
                const jobListColumn = document.querySelector('.job-list-column');
                if (jobListColumn) {
                    jobListColumn.scrollTop = 0;
                }
            })
            .catch(error => {
                console.error('Error loading jobs:', error);
                jobCardsContainer.style.opacity = '1';
                alert('Failed to load jobs. Please try again.');
            });
    }

    function updatePaginationActiveState(page) {
        document.querySelectorAll('.page-item').forEach(item => {
            item.classList.remove('active');
            item.removeAttribute('aria-current');
        });
        
        const activePageLink = document.querySelector(`.page-link[data-page="${page}"]`);
        if (activePageLink) {
            const pageItem = activePageLink.closest('.page-item');
            pageItem.classList.add('active');
            pageItem.setAttribute('aria-current', 'page');
        }
        
        const prevButton = document.querySelector('.page-link[aria-label="Previous"]');
        const nextButton = document.querySelector('.page-link[aria-label="Next"]');
        
        if (prevButton) {
            const prevItem = prevButton.closest('.page-item');
            if (page <= 1) {
                prevItem.classList.add('disabled');
                prevButton.setAttribute('tabindex', '-1');
                prevButton.setAttribute('aria-disabled', 'true');
            } else {
                prevItem.classList.remove('disabled');
                prevButton.removeAttribute('tabindex');
                prevButton.removeAttribute('aria-disabled');
                prevButton.dataset.page = page - 1;
            }
        }
        
        if (nextButton) {
            const nextItem = nextButton.closest('.page-item');
            if (page >= totalPages) {
                nextItem.classList.add('disabled');
                nextButton.setAttribute('tabindex', '-1');
                nextButton.setAttribute('aria-disabled', 'true');
            } else {
                nextItem.classList.remove('disabled');
                nextButton.removeAttribute('tabindex');
                nextButton.removeAttribute('aria-disabled');
                nextButton.dataset.page = page + 1;
            }
        }
    }
</script>

</body>
</html>
