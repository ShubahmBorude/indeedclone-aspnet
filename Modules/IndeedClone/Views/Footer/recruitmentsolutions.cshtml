@{
    Layout = "_AuthNavbarLayout";
    ViewData["Title"] = "Recruitment Solutions - IndeedClone";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <!-- jquery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- ionicons -->
    <script type="module" src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.js"></script>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/footer/solutions.css" />
</head>
<body>

<div class="solutions-page">
    <!-- Hero Section -->
    <section class="solutions-hero">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">Recruitment <span style="color: rgb(37, 90, 168);">Solutions</span></h1>
                <p class="hero-subtitle">End-to-end hiring tools to find and attract the best talent</p>
            </div>
        </div>
    </section>

    <!-- Features Grid -->
    <section class="features-section">
        <div class="container">
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon" style="background: rgba(37, 90, 168, 0.1);">
                        <i class="bi bi-megaphone" style="color: rgb(37, 90, 168);"></i>
                    </div>
                    <h3>Job Posting</h3>
                    <p>Create and publish engaging job descriptions that attract qualified candidates.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon" style="background: rgba(37, 90, 168, 0.1);">
                        <i class="bi bi-people" style="color: rgb(37, 90, 168);"></i>
                    </div>
                    <h3>Candidate Search</h3>
                    <p>Access our database of millions of resumes and proactively find talent.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon" style="background: rgba(37, 90, 168, 0.1);">
                        <i class="bi bi-filter-square" style="color: rgb(37, 90, 168);"></i>
                    </div>
                    <h3>Smart Filtering</h3>
                    <p>Advanced filters to narrow down candidates by skills, experience, and location.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon" style="background: rgba(37, 90, 168, 0.1);">
                        <i class="bi bi-graph-up" style="color: rgb(37, 90, 168);"></i>
                    </div>
                    <h3>Analytics Dashboard</h3>
                    <p>Track job performance, application rates, and candidate quality.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon" style="background: rgba(37, 90, 168, 0.1);">
                        <i class="bi bi-envelope" style="color: rgb(37, 90, 168);"></i>
                    </div>
                    <h3>Automated Communications</h3>
                    <p>Send personalized emails and updates to candidates automatically.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon" style="background: rgba(37, 90, 168, 0.1);">
                        <i class="bi bi-calendar-check" style="color: rgb(37, 90, 168);"></i>
                    </div>
                    <h3>Interview Scheduling</h3>
                    <p>Integrated calendar system to schedule interviews seamlessly.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section class="how-it-works">
        <div class="container">
            <h2 class="section-title">How It Works</h2>
            <div class="steps-container">
                <div class="step-item">
                    <div class="step-number">1</div>
                    <div class="step-content">
                        <h4>Post Your Job</h4>
                        <p>Create a detailed job description with requirements, benefits, and company culture.</p>
                    </div>
                </div>
                <div class="step-item">
                    <div class="step-number">2</div>
                    <div class="step-content">
                        <h4>Reach Candidates</h4>
                        <p>Your job is shown to millions of active job seekers matching your criteria.</p>
                    </div>
                </div>
                <div class="step-item">
                    <div class="step-number">3</div>
                    <div class="step-content">
                        <h4>Review Applications</h4>
                        <p>Manage and filter applications through our intuitive dashboard.</p>
                    </div>
                </div>
                <div class="step-item">
                    <div class="step-number">4</div>
                    <div class="step-content">
                        <h4>Hire the Best</h4>
                        <p>Schedule interviews and make offers to your ideal candidates.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Success Stories -->
    <section class="testimonials-section">
        <div class="container">
            <h2 class="section-title">Success Stories</h2>
            <div class="testimonials-grid">
                <div class="testimonial-card">
                    <i class="bi bi-quote quote-icon"></i>
                    <p class="testimonial-text">"IndeedClone helped us fill 5 technical positions in just 2 weeks. The quality of candidates was exceptional!"</p>
                    <div class="testimonial-author">
                        <div class="author-avatar" style="background: rgb(37, 90, 168);">R</div>
                        <div class="author-info">
                            <h5>Rajesh Kumar</h5>
                            <p>HR Manager, TechSolutions</p>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card">
                    <i class="bi bi-quote quote-icon"></i>
                    <p class="testimonial-text">"The analytics dashboard gives us valuable insights into our hiring process. Worth every rupee!"</p>
                    <div class="testimonial-author">
                        <div class="author-avatar" style="background: rgb(37, 90, 168);">P</div>
                        <div class="author-info">
                            <h5>Priya Sharma</h5>
                            <p>Talent Acquisition Lead, InnovateCorp</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="solutions-cta">
        <div class="container">
            <div class="cta-content">
                <h2>Transform Your Hiring Process</h2>
                <p>Join 10,000+ companies using IndeedClone for recruitment</p>
                <a href="@Url.Action("Pricing", "FooterInfo")" class="cta-button" style="background: rgb(37, 90, 168);">
                    View Pricing <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </section>
</div>



</body>
</html>