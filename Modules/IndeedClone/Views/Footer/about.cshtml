@{
    Layout = "_AuthNavbarLayout";
    ViewData["Title"] = "About IndeedClone - Job Search Platform";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"]</title>
    
    <!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">
    
    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <link rel="stylesheet" href="~/css/footer/about.css" />

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <!-- jquery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- ionicons -->
    <script type="module" src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.js"></script>

</head>

<body>

<div class="about-page">
    <!-- Hero Section -->
    <section class="about-hero">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">About <span class="text-primary">IndeedClone</span></h1>
                <p class="hero-subtitle">India's fastest growing job search platform connecting millions of job seekers with their dream careers</p>
            </div>
        </div>
    </section>

    <!-- Our Story Section -->
    <section class="story-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h2 class="section-title">Our Story</h2>
                    <p class="story-text">
                        Founded in 2024, IndeedClone was built with a simple mission: to make job searching easier, faster, and more accessible for everyone in India. What started as a small project has now grown into a trusted platform serving thousands of job seekers and employers across the country.
                    </p>
                    <p class="story-text">
                        We believe that finding the right job shouldn't be complicated. That's why we've created an intuitive platform that uses advanced technology to match talented professionals with companies that need their skills.
                    </p>
                </div>
                <div class="col-lg-6">
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-number">50K+</div>
                            <div class="stat-label">Jobs Posted</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-number">100K+</div>
                            <div class="stat-label">Active Job Seekers</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-number">10K+</div>
                            <div class="stat-label">Companies</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-number">95%</div>
                            <div class="stat-label">Satisfaction Rate</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Vision -->
    <section class="mission-section">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <div class="mission-card">
                        <div class="mission-icon">
                            <i class="bi bi-bullseye"></i>
                        </div>
                        <h3>Our Mission</h3>
                        <p>To empower every professional in India to find meaningful employment by providing a seamless, transparent, and efficient job search experience.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mission-card">
                        <div class="mission-icon">
                            <i class="bi bi-eye"></i>
                        </div>
                        <h3>Our Vision</h3>
                        <p>To become India's most trusted job search platform, where every job seeker finds their perfect role and every employer discovers their ideal candidate.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Values -->
    <section class="values-section">
        <div class="container">
            <h2 class="section-title text-center">Our Core Values</h2>
            <div class="values-grid">
                <div class="value-card">
                    <div class="value-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h4>Trust & Transparency</h4>
                    <p>We ensure all job postings are verified and authentic, building trust between job seekers and employers.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="bi bi-lightning-charge"></i>
                    </div>
                    <h4>Speed & Efficiency</h4>
                    <p>Our smart matching algorithm helps job seekers find relevant opportunities faster.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="bi bi-people"></i>
                    </div>
                    <h4>User-Centric Approach</h4>
                    <p>Every feature we build is designed with our users' needs in mind.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon">
                        <i class="bi bi-graph-up"></i>
                    </div>
                    <h4>Continuous Innovation</h4>
                    <p>We constantly evolve our platform to meet changing market needs.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section class="how-it-works">
        <div class="container">
            <h2 class="section-title text-center">How IndeedClone Works</h2>
            <div class="steps-container">
                <div class="step-item">
                    <div class="step-number">1</div>
                    <div class="step-content">
                        <h4>Search Jobs</h4>
                        <p>Use our powerful search with filters like location, salary, job type, and more to find opportunities that match your criteria.</p>
                    </div>
                </div>
                <div class="step-item">
                    <div class="step-number">2</div>
                    <div class="step-content">
                        <h4>View Details</h4>
                        <p>Click on any job card to see the full description, requirements, benefits, and company information.</p>
                    </div>
                </div>
                <div class="step-item">
                    <div class="step-number">3</div>
                    <div class="step-content">
                        <h4>Apply Online</h4>
                        <p>Submit your application directly through our platform with just a few clicks.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Choose Us -->
    <section class="why-choose-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h2 class="section-title">Why Choose IndeedClone?</h2>
                    <ul class="benefits-list">
                        <li>
                            <i class="bi bi-check-circle-fill text-primary"></i>
                            <span><strong>50,000+ active jobs</strong> across various industries</span>
                        </li>
                        <li>
                            <i class="bi bi-check-circle-fill text-primary"></i>
                            <span><strong>Advanced filters</strong> to narrow down your search</span>
                        </li>
                        <li>
                            <i class="bi bi-check-circle-fill text-primary"></i>
                            <span><strong>Real-time job alerts</strong> matching your preferences</span>
                        </li>
                        <li>
                            <i class="bi bi-check-circle-fill text-primary"></i>
                            <span><strong>Verified companies</strong> and authentic job postings</span>
                        </li>
                        <li>
                            <i class="bi bi-check-circle-fill text-primary"></i>
                            <span><strong>Mobile-friendly design</strong> to search on the go</span>
                        </li>
                        <li>
                            <i class="bi bi-check-circle-fill text-primary"></i>
                            <span><strong>Free for job seekers</strong> - always</span>
                        </li>
                    </ul>
                </div>
                <div class="col-lg-6">
                    <div class="testimonial-card">
                        <i class="bi bi-quote quote-icon"></i>
                        <p class="testimonial-text">I found my dream job as a Software Developer through IndeedClone within just 2 weeks of searching. The filters helped me find exactly what I was looking for!</p>
                        <div class="testimonial-author">
                            <div class="author-avatar">R</div>
                            <div class="author-info">
                                <h5>Rahul Sharma</h5>
                                <p>Software Developer at Tech Solutions</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section class="team-section">
        <div class="container">
            <h2 class="section-title text-center">Meet Our Team</h2>
            <p class="team-subtitle text-center">The passionate people behind IndeedClone</p>
            <div class="team-grid">
                <div class="team-card">
                    <div class="team-avatar">S</div>
                    <h4>Shubham Borude</h4>
                    <p>Founder & CEO</p>
                </div>
                <div class="team-card">
                    <div class="team-avatar">P</div>
                    <h4>Priya Singh</h4>
                    <p>Head of Product</p>
                </div>
                <div class="team-card">
                    <div class="team-avatar">S</div>
                    <h4>Shubham Borude</h4>
                    <p>Lead Developer</p>
                </div>
                <div class="team-card">
                    <div class="team-avatar">N</div>
                    <h4>Neha Gupta</h4>
                    <p>HR & Operations</p>
                </div>
            </div>
        </div>
    </section>

   <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div class="cta-content">
                <h2>Ready to find your dream job?</h2>
                <p>Join thousands of job seekers who have already found their perfect role through IndeedClone</p>
                <div class="cta-buttons">
                    <a href="@Url.Action("Retrieve", "IndeedClone")" class="btn btn-primary btn-lg" style="background-color: rgb(37, 90, 168); color: #fff; font-weight: 700;">Search Jobs</a>
                    <a href="@Url.Action("Retrieve", "JobPost")" class="btn btn-outline-primary btn-lg" style="font-weight: 700;">For Employers</a>
                </div>
            </div>
        </div>
    </section>
</div>


</body>
</html>