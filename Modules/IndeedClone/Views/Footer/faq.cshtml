@{
    Layout = "_AuthNavbarLayout";
    ViewData["Title"] = "FAQ - IndeedClone";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <!-- jquery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- ionicons -->
    <script type="module" src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.js"></script>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/footer/faq.css" />
</head>
<body>

<div class="faq-page">
    <!-- Hero Section -->
    <section class="faq-hero">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">Frequently Asked <span style="color: rgb(37, 90, 168);">Questions</span></h1>
                <p class="hero-subtitle">Find answers to common questions about job searching, applying, and using IndeedClone</p>
            </div>
        </div>
    </section>

    <!-- Search FAQ Section -->
    <section class="faq-search-section">
        <div class="container">
            <div class="search-container">
                <div class="search-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" class="faq-search-input" id="faqSearch" placeholder="Search frequently asked questions...">
                </div>
                <p class="search-hint">Popular searches: apply, resume, interview, salary, remote work</p>
            </div>
        </div>
    </section>

    <!-- FAQ Categories -->
    <section class="faq-categories">
        <div class="container">
            <div class="categories-grid">
                <button class="category-btn active" data-category="all">All Questions</button>
                <button class="category-btn" data-category="jobseekers">Job Seekers</button>
                <button class="category-btn" data-category="employers">Employers</button>
                <button class="category-btn" data-category="account">Account & Profile</button>
                <button class="category-btn" data-category="applications">Applications</button>
                <button class="category-btn" data-category="technical">Technical Support</button>
            </div>
        </div>
    </section>

    <!-- FAQ Accordion Section -->
    <section class="faq-accordion-section">
        <div class="container">
            <div class="faq-container">
                <!-- Category: Job Seekers -->
                <div class="faq-category" data-category="jobseekers">
                    <h2 class="category-title"><i class="bi bi-people" style="color: rgb(37, 90, 168);"></i> For Job Seekers</h2>
                    
                    <div class="accordion" id="jobSeekerAccordion">
                        <!-- Question 1 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#jobSeeker1">
                                    How do I search for jobs on IndeedClone?
                                </button>
                            </h3>
                            <div id="jobSeeker1" class="accordion-collapse collapse show" data-bs-parent="#jobSeekerAccordion">
                                <div class="accordion-body">
                                    Searching for jobs is easy! Simply enter keywords (job title, skills, or company) in the search bar and add a location. You can also use our advanced filters to narrow down results by salary, job type, work arrangement, date posted, and more. Click on any job card to view full details and apply.
                                </div>
                            </div>
                        </div>

                        <!-- Question 2 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#jobSeeker2">
                                    Is IndeedClone free for job seekers?
                                </button>
                            </h3>
                            <div id="jobSeeker2" class="accordion-collapse collapse" data-bs-parent="#jobSeekerAccordion">
                                <div class="accordion-body">
                                    Yes! IndeedClone is completely free for job seekers. You can search for jobs, view detailed descriptions, and apply to positions without any cost. We believe everyone should have access to their dream career opportunities.
                                </div>
                            </div>
                        </div>

                        <!-- Question 3 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#jobSeeker3">
                                    How do I create a profile?
                                </button>
                            </h3>
                            <div id="jobSeeker3" class="accordion-collapse collapse" data-bs-parent="#jobSeekerAccordion">
                                <div class="accordion-body">
                                    Click on "Sign In" at the top right corner and select "Create Account". Fill in your basic information, including name, email, and password. Once registered, you can add your resume, skills, work experience, and education to make your profile stand out to employers.
                                </div>
                            </div>
                        </div>

                        <!-- Question 4 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#jobSeeker4">
                                    What do the filter badges mean?
                                </button>
                            </h3>
                            <div id="jobSeeker4" class="accordion-collapse collapse" data-bs-parent="#jobSeekerAccordion">
                                <div class="accordion-body">
                                    Filter badges show the number of active filters you've applied. For example, if you select multiple job types, you'll see a badge with the count next to "Job Type". This helps you keep track of your current search criteria. Click "Clear all filters" to reset your search.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Category: Employers -->
                <div class="faq-category" data-category="employers">
                    <h2 class="category-title"><i class="bi bi-briefcase" style="color: rgb(37, 90, 168);"></i> For Employers</h2>
                    
                    <div class="accordion" id="employerAccordion">
                        <!-- Question 1 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#employer1">
                                    How do I post a job?
                                </button>
                            </h3>
                            <div id="employer1" class="accordion-collapse collapse" data-bs-parent="#employerAccordion">
                                <div class="accordion-body">
                                    To post a job, click on "Employers / Post Job" at the top of the page. You'll need to create an employer account or sign in. Fill in the job details including title, description, requirements, salary range, and location. Review and publish your job posting.
                                </div>
                            </div>
                        </div>

                        <!-- Question 2 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#employer2">
                                    How much does it cost to post a job?
                                </button>
                            </h3>
                            <div id="employer2" class="accordion-collapse collapse" data-bs-parent="#employerAccordion">
                                <div class="accordion-body">
                                    We offer flexible pricing plans for employers. Basic job postings start at free, with premium options starting from ₹2,999 per posting that include featured listings, priority visibility, and advanced analytics. Contact our sales team for volume discounts.
                                </div>
                            </div>
                        </div>

                        <!-- Question 3 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#employer3">
                                    Can I edit my job posting after publishing?
                                </button>
                            </h3>
                            <div id="employer3" class="accordion-collapse collapse" data-bs-parent="#employerAccordion">
                                <div class="accordion-body">
                                    Yes, you can edit your job posting anytime from your employer dashboard. Log in to your employer account, go to "My Jobs", and click on the edit icon next to the posting you want to modify. Changes will be reflected immediately.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Category: Account & Profile -->
                <div class="faq-category" data-category="account">
                    <h2 class="category-title"><i class="bi bi-person-circle" style="color: rgb(37, 90, 168);"></i> Account & Profile</h2>
                    
                    <div class="accordion" id="accountAccordion">
                        <!-- Question 1 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#account1">
                                    How do I reset my password?
                                </button>
                            </h3>
                            <div id="account1" class="accordion-collapse collapse" data-bs-parent="#accountAccordion">
                                <div class="accordion-body">
                                    Click on "Sign In", then select "Forgot Password". Enter your registered email address, and we'll send you a password reset link. Follow the instructions to create a new password. If you don't receive the email, check your spam folder.
                                </div>
                            </div>
                        </div>

                        <!-- Question 2 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#account2">
                                    How do I update my profile information?
                                </button>
                            </h3>
                            <div id="account2" class="accordion-collapse collapse" data-bs-parent="#accountAccordion">
                                <div class="accordion-body">
                                    Sign in to your account and click on your profile picture or name. Select "Profile Settings" from the dropdown menu. Here you can update your personal information, resume, skills, work experience, education, and notification preferences.
                                </div>
                            </div>
                        </div>

                        <!-- Question 3 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#account3">
                                    Can I delete my account?
                                </button>
                            </h3>
                            <div id="account3" class="accordion-collapse collapse" data-bs-parent="#accountAccordion">
                                <div class="accordion-body">
                                    Yes, you can delete your account from the profile settings. Go to "Profile Settings", scroll to the bottom, and click "Delete Account". Please note that this action is permanent and will remove all your data, including saved jobs and applications.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Category: Applications -->
                <div class="faq-category" data-category="applications">
                    <h2 class="category-title"><i class="bi bi-send" style="color: rgb(37, 90, 168);"></i> Applications</h2>
                    
                    <div class="accordion" id="applicationAccordion">
                        <!-- Question 1 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#app1">
                                    How do I apply for a job?
                                </button>
                            </h3>
                            <div id="app1" class="accordion-collapse collapse" data-bs-parent="#applicationAccordion">
                                <div class="accordion-body">
                                    Once you find a job you're interested in, click on the job card to view full details. Click the "Apply now" button on the right side of the job details panel. Follow the application instructions - you may be asked to upload your resume, answer questions, or visit the employer's website.
                                </div>
                            </div>
                        </div>

                        <!-- Question 2 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#app2">
                                    How do I track my applications?
                                </button>
                            </h3>
                            <div id="app2" class="accordion-collapse collapse" data-bs-parent="#applicationAccordion">
                                <div class="accordion-body">
                                    Sign in to your account and go to "My Applications" from your profile dropdown. Here you'll see all the jobs you've applied for, along with their status (Applied, Under Review, Interview, etc.). You can also withdraw applications if needed.
                                </div>
                            </div>
                        </div>

                        <!-- Question 3 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#app3">
                                    Can I save jobs to apply later?
                                </button>
                            </h3>
                            <div id="app3" class="accordion-collapse collapse" data-bs-parent="#applicationAccordion">
                                <div class="accordion-body">
                                    Absolutely! Click the three dots menu on any job card and select "Save job". Saved jobs can be accessed from your profile under "Saved Jobs". This feature helps you keep track of interesting positions you want to review or apply to later.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Category: Technical Support -->
                <div class="faq-category" data-category="technical">
                    <h2 class="category-title"><i class="bi bi-gear" style="color: rgb(37, 90, 168);"></i> Technical Support</h2>
                    
                    <div class="accordion" id="techAccordion">
                        <!-- Question 1 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#tech1">
                                    What browsers does IndeedClone support?
                                </button>
                            </h3>
                            <div id="tech1" class="accordion-collapse collapse" data-bs-parent="#techAccordion">
                                <div class="accordion-body">
                                    IndeedClone works best on the latest versions of Chrome, Firefox, Safari, and Edge. We recommend keeping your browser updated for the best experience. The site is also fully responsive and works on mobile devices.
                                </div>
                            </div>
                        </div>

                        <!-- Question 2 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#tech2">
                                    Why am I not receiving email notifications?
                                </button>
                            </h3>
                            <div id="tech2" class="accordion-collapse collapse" data-bs-parent="#techAccordion">
                                <div class="accordion-body">
                                    First, check your spam or junk folder. If emails aren't there, verify your notification settings in Profile Settings. Make sure your email address is correct and you've opted in to receive notifications. Still having issues? Contact our support team.
                                </div>
                            </div>
                        </div>

                        <!-- Question 3 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#tech3">
                                    How do I report a bug or technical issue?
                                </button>
                            </h3>
                            <div id="tech3" class="accordion-collapse collapse" data-bs-parent="#techAccordion">
                                <div class="accordion-body">
                                    Visit our Contact page and select "Technical Support" from the subject dropdown. Provide detailed information about the issue, including steps to reproduce it, your browser, and any error messages you've seen. Our team will investigate and respond promptly.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Still Have Questions Section -->
    <section class="still-questions-section">
        <div class="container">
            <div class="questions-card">
                <h2>Still have questions?</h2>
                <p>Can't find the answer you're looking for? We're here to help!</p>
                <div class="questions-buttons">
                    <a href="@Url.Action("Contact", "FooterInfo")" class="btn-contact" style="background: rgb(37, 90, 168);">
                        <i class="bi bi-envelope"></i> Contact Support
                    </a>
                    <a href="#" class="btn-chat" style="border-color: rgb(37, 90, 168); color: rgb(37, 90, 168);">
                        <i class="bi bi-chat-dots"></i> Live Chat
                    </a>
                </div>
            </div>
        </div>
    </section>
</div>


<!-- FAQ Search Script -->
<script>
    $(document).ready(function() {
        // Search functionality
        $("#faqSearch").on("keyup", function() {
            var value = $(this).val().toLowerCase();
            $(".accordion-item").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
            
            // Show/hide categories based on visible items
            $(".faq-category").each(function() {
                var visibleItems = $(this).find(".accordion-item:visible").length;
                if (visibleItems === 0) {
                    $(this).hide();
                } else {
                    $(this).show();
                }
            });
        });

        // Category filter
        $(".category-btn").click(function() {
            $(".category-btn").removeClass("active");
            $(this).addClass("active");
            
            var category = $(this).data("category");
            
            if (category === "all") {
                $(".faq-category").show();
                $(".accordion-item").show();
            } else {
                $(".faq-category").hide();
                $(`.faq-category[data-category="${category}"]`).show();
            }
        });
    });
</script>

</body>
</html>