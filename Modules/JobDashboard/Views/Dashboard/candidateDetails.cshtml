@using IndeedClone.Modules.Shared.Enums
@model IndeedClone.Modules.JobDashboard.DTO.CandidateDetailsDTO
@{
    Layout = "_DashboardNavbarLayout";
    ViewData["Title"] = " Candidate Details - IndeedClone";

 }

<!DOCTYPE html>
<html>

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0">

    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap-5 and custom CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>

    <!-- custom css -->
    <link rel="stylesheet" href="~/css/dashboard/candidatedeatils.css">
    <link rel="stylesheet" href="~/css/errors/error.css" />    

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    @* <style>background-color: #f3f5f7;</style> *@

</head>

<body>


<!-- Flash Messages -->
<div class="flash-messages-container">
    @if (TempData["Success"] != null)
    {
         <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                    <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                     <span>@Html.Raw(TempData["Success"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
     }

    @if (TempData["Error"] != null)
    {
         <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                     <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </svg>
                      <span>@Html.Raw(TempData["Error"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
         </div>
     }
</div>

    
    <div class="dashboard-wrapper">
        <!-- Header Section -->
        <div class="dashboard-header">
            <div class="header-left">
                <h1 class="dashboard-title">Candidate Profile</h1>
                <div class="job-subtitle">
                    <span><i class="bi bi-briefcase me-2"></i>@Model.CandidateJobTitle</span>
                    <span class="separator">•</span>
                    <span><i class="bi bi-building me-2"></i>@Model.CandidateCompanyName</span>
                </div>
            </div>

          
            <div class="action-buttons-header">
                @if (Model.Status == JobApplicationStatus.SUBMITTED)
                {
                    <span class="status-badge-large submitted">Submitted</span>
                }
                else if (Model.Status == JobApplicationStatus.SHORTLISTED)
                {
                    <span class="status-badge-large shortlisted">Shortlisted</span>
                }
                else if (Model.Status == JobApplicationStatus.REJECTED)
                {
                    <span class="status-badge-large rejected">Rejected</span>
                }
             </div>
            
        </div>

        <!-- Single Profile Card -->
        <div class="profile-card">
            <!-- Candidate Header -->
            <div class="candidate-header">
                <div class="candidate-info">
                    <h2>@Model.CandidateFullName</h2>
                    <div class="candidate-meta">
                        <span><i class="bi bi-envelope"></i>@Model.CandidateEmail</span>
                        <span><i class="bi bi-telephone"></i>@Model.CandidateMobileNumber</span>
                        <span><i class="bi bi-geo-alt"></i> @Model.CandidateJobLocation, @Model.CandidateCity</span>
                    </div>
                </div>
            </div>

            <!-- Personal Details - 3 Column Grid -->
            <div class="info-grid">
                <div class="info-item">
                    <span class="info-label">Total Experience</span>
                    <span class="info-value">@Model.TotalExperience</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Skills Experience</span>
                    <span class="info-value">@Model.SkillsExperience</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Current CTC</span>
                    <span class="info-value">₹@Model.CurrentCTC.ToString("N0")</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Expected CTC</span>
                    <span class="info-value">₹@Model.ExpectedCTC.ToString("N0")</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Notice Period</span>
                    <span class="info-value">@Model.NoticePeriod</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Education</span>
                    <span class="info-value small">@Model.Education</span>
                </div>
            </div>

            <div class="divider">

            <!-- Work Experience -->
            <div class="section-title">
                Work Experience
            </div>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-icon">
                        <i class="bi bi-building"></i>
                    </div>
                    <div class="timeline-content">
                        <div class="timeline-title">@Model.CandidateJobTitle</div>
                        <div class="timeline-subtitle">@Model.CandidateCompanyName</div>
                    </div>
                </div>
            </div>


            <!-- Resume -->
            <div class="section-title">
                <i class="bi bi-file-earmark-text"></i> Resume
            </div>
            <div class="resume-preview">
                <div class="resume-header">
                    <h3>
                        <i class="bi bi-file-earmark-pdf"></i>
                        @Model.FileName
                    </h3>
                    <a href="@Url.Action("DownloadCV", "JobDashboard", new { applicationUid = Model.ApplicationUid })" class="resume-download-btn">
                        <i class="bi bi-download"></i> Download
                    </a>
                </div>

                <div class="resume-preview-body">
                    @if (!string.IsNullOrEmpty(Model.FilePath)  && Model.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                    {
                        <iframe class="resume-iframe"
                                src="@Url.Action("PreviewCV","JobDashboard", new { applicationUid = Model.ApplicationUid })#toolbar=0&navpanes=0&scrollbar=0"
                                width="100%"
                                height="600px"
                                style="border:none;">
                        </iframe>
                    }
                    else
                    {
                        <div style="text-align:center; padding:40px;">
                            <i class="bi bi-file-earmark"></i>
                            <p>Preview not available</p>
                            <p style="font-size:13px;">
                                Download file to view resume
                            </p>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
    

</body>
</html>