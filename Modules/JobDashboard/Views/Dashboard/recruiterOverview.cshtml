@using IndeedClone.Modules.IndeedClone.Helpers
@using IndeedClone.Modules.Shared.Enums
@model IndeedClone.Modules.JobDashboard.DTO.RecruiterOverviewPaginatedDTO
@{
    Layout = "_DashboardNavbarLayout";
    ViewData["Title"] = " Candidate Overview - IndeedClone";

 }

<!DOCTYPE html>
<html>

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0">

    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap-5 and custom CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>

    <!-- custom css -->
    <link rel="stylesheet" href="~/css/dashboard/recruiteroverview.css">
    <link rel="stylesheet" href="~/css/errors/error.css" />    

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    @* <style>background-color: #f3f5f7;</style> *@

</head>

<body>


<!-- Flash Messages -->
<div class="flash-messages-container">
    @if (TempData["Success"] != null)
    {
         <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                    <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                     <span>@Html.Raw(TempData["Success"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
     }

    @if (TempData["Error"] != null)
    {
         <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                     <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </svg>
                      <span>@Html.Raw(TempData["Error"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
         </div>
     }
</div>


<div class="dashboard-wrapper">
        <!-- Header Section -->
        <div class="dashboard-header">
            <div>
                <h1 class="dashboard-title">Job Dashboard</h1>
                <p class="dashboard-subtitle">Manage your job postings and track applicants</p>
            </div>
            <a href="@Url.Action("Retrieve", "JobPost")" class="btn-primary">
                <i class="bi bi-plus-circle"></i> Post New Job
            </a>
        </div>

        <!-- Summary Cards -->
        <div class="summary-cards">
            <div class="summary-card">
                <div class="summary-icon blue">
                    <i class="bi bi-briefcase"></i>
                </div>
                <div class="summary-details">
                    <span class="summary-label">Total Jobs</span>
                    <span class="summary-value">@(Model?.TotalJobs)</span>
                </div>
            </div>

            <div class="summary-card">
                <div class="summary-icon green">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div class="summary-details">
                    <span class="summary-label">Active Jobs</span>
                    <span class="summary-value">@(Model?.ActiveJobs)</span>
                </div>
            </div>

            <div class="summary-card">
                <div class="summary-icon purple">
                    <i class="bi bi-people"></i>
                </div>
                <div class="summary-details">
                    <span class="summary-label">Total Applications</span>
                    <span class="summary-value">@(Model.TotalApplications)</span>
                </div>
            </div>

            <div class="summary-card">
                <div class="summary-icon orange">
                    <i class="bi bi-star"></i>
                </div>
                <div class="summary-details">
                    <span class="summary-label">Shortlisted</span>
                    <span class="summary-value">@(Model?.ShortListed)</span>
                </div>
            </div>
        </div>

        <!-- Search & Filter Bar -->
        <div class="search-filter-bar">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" id="searchInput" placeholder="Search by job title..." onkeyup="filterJobs()">
            </div>
            <div class="filter-actions">
                <select class="btn-outline" id="statusFilter" onchange="filterJobs()" style="padding: 8px 32px 8px 16px;">
                    <option value="all">All Status</option>
                    <option value="open">Open</option>
                    <option value="closed">Closed</option>
                </select>
                <button class="btn-outline" onclick="exportTable()">
                    <i class="bi bi-download"></i> Export
                </button>
            </div>
        </div>

        <!-- Jobs Table -->
        <div class="table-card">
            <div class="table-responsive">
                <table id="jobsTable">
                    <thead>
                        <tr>
                            <th>Job Title</th>
                            <th>Status</th>
                            <th>Total Apps</th>
                            <th>Submitted</th>
                            <th>Shortlisted</th>
                            <th>Rejected</th>
                            <th>Last Application</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>

                    @if (Model.Jobs != null && Model.Jobs.Count > 0)
                    {
                      @foreach (var job in Model.Jobs)
                      {
                        <tr>
                            <td>
                                <a href="@Url.Action("Applicants", "JobDashboard", new { jobUid = job.JobUid })" class="job-title-link">
                                    @job.JobTitle
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                                <div class="job-meta">Posted - @job.Posted.ToString("MMM dd, yyyy")</div>
                            </td>
                            <td><span class="status-badge @(job.Status == JobPostStatus.ACTIVE ? "open" : "closed")">@(job.Status == JobPostStatus.ACTIVE ? "Open" : "Closed")</span></td>
                            <td><span class="number-highlight">@job.TotalApplicationsPerJob</span></td>
                            <td>@job.SubmittedCount</td>
                            <td>@job.ShortlistedCountPerJob</td>
                            <td>@job.RejectedCount</td>
                            <td>@((job.LastApplication != DateTime.MinValue) ? job.LastApplication.ToString("MMM dd, yyyy") : "None")</td>
                            <td>
                                <a href="@Url.Action("Applicants", "JobDashboard", new { jobUid = job.JobUid })" class="view-btn">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                      }
                    }
                    else
                    {
                        <tr>
                        <td colspan="8" class="text-center"> No Records  </td>
                        </tr>

                    }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="table-pagination">
           <div class="pagination-info">
                Showing <strong>
                    @(((Model.Pagination.CurrentPage - 1) * Model.Pagination.PageSize) + 1)- @Math.Min(Model.Pagination.CurrentPage * Model.Pagination.PageSize, Model.Pagination.TotalItems)
                    </strong> of <strong>@Model.Pagination.TotalItems</strong> jobs
           </div>

             <ul class="pagination">
                <li class="page-item @(Model.Pagination.HasPrevious ? "" : "disabled")">
                    @if (Model.Pagination.HasPrevious)
                    {
                        <a class="page-link" href="@Url.Action("Retrieve", new { page = Model.Pagination.CurrentPage - 1, pageSize = Model.Pagination.PageSize })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    }
                    else
                    {
                        <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                    }
                </li>

                 @{
                    int startPage = Math.Max(1, Model.Pagination.CurrentPage - 2);
                    int endPage = Math.Min(Model.Pagination.TotalPages, Model.Pagination.CurrentPage + 2);
                    
                    if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Retrieve", new { page = 1, pageSize = Model.Pagination.PageSize })">1</a>
                        </li>
                        @if (startPage > 2)
                        {
                            <li class="page-item"><span class="page-link">...</span></li>
                        }
                    }
                    
                    for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.Pagination.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Retrieve", new { page = i, pageSize = Model.Pagination.PageSize })">@i</a>
                        </li>
                    }
                    
                    if (endPage < Model.Pagination.TotalPages)
                    {
                        @if (endPage < Model.Pagination.TotalPages - 1)
                        {
                            <li class="page-item"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Retrieve", new { page = Model.Pagination.TotalPages, pageSize = Model.Pagination.PageSize })">@Model.Pagination.TotalPages</a>
                        </li>
                    }
                }

                <li class="page-item @(Model.Pagination.HasNext ? "" : "disabled")">
                    <a class="page-link" href="@Url.Action("Retrieve", new { page = Model.Pagination.CurrentPage + 1, pageSize = Model.Pagination.PageSize })">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>

            </ul>
       </div>

    </div>

    <!-- JavaScript -->
    <script>
        function filterJobs() {
            const searchInput = document.getElementById('searchInput').value.toLowerCase();
            const statusFilter = document.getElementById('statusFilter').value;
            const rows = document.querySelectorAll('#jobsTable tbody tr');
            
            rows.forEach(row => {
                const jobTitle = row.cells[0].innerText.toLowerCase();
                const status = row.cells[1].innerText.toLowerCase().trim();
                
                let matchesSearch = jobTitle.includes(searchInput);
                let matchesStatus = statusFilter === 'all' || status === statusFilter;
                
                if (matchesSearch && matchesStatus) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        function exportTable() {
            const table = document.getElementById('jobsTable');
            const rows = table.querySelectorAll('tr');
            let csv = [];
            
            rows.forEach(row => {
                const cells = row.querySelectorAll('th, td');
                const rowData = [];
                cells.forEach(cell => {
                    if (cell.querySelector('.job-title-link')) {
                        rowData.push(cell.querySelector('.job-title-link').innerText.trim());
                    } else if (cell.querySelector('.status-badge')) {
                        rowData.push(cell.querySelector('.status-badge').innerText.trim());
                    } else {
                        rowData.push(cell.innerText.trim());
                    }
                });
                csv.push(rowData.join(','));
            });
            
            const csvContent = csv.join('\n');
            const blob = new Blob([csvContent], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'jobs_dashboard.csv';
            a.click();
        }

        // Sort table by column (for Last Application Date - newest first)
        function sortTable() {
            const table = document.getElementById('jobsTable');
            const tbody = table.tBodies[0];
            const rows = Array.from(tbody.rows);
            
            rows.sort((a, b) => {
                const dateA = a.cells[6].innerText;
                const dateB = b.cells[6].innerText;
                
                // Simple sort - in real app you'd parse dates properly
                if (dateA.includes('hour') && !dateB.includes('hour')) return -1;
                if (!dateA.includes('hour') && dateB.includes('hour')) return 1;
                return 0;
            });
            
            tbody.append(...rows);
        }

        // Apply default sort on page load
        document.addEventListener('DOMContentLoaded', sortTable);
    </script>

</body>
</html>
