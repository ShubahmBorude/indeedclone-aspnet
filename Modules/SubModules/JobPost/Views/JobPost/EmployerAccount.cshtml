    <script>
        function toggleDropdown() {
            const dropdownMenu = document.getElementById('dropdownMenu');
            dropdownMenu.classList.toggle('show');
        }

        function selectOption(option) {
            const dropdownInput = document.querySelector('.dropdown-input');
            const chip = document.createElement('div');
            chip.classList.add('chip');
            chip.textContent = option;
            const removeButton = document.createElement('span');
            removeButton.classList.add('remove');
            removeButton.textContent = '×';
            removeButton.addEventListener('click', (event) => {
                event.stopPropagation();
                chip.remove();
                document.getElementById('howDidYouHear').value = ''; // Reset the value of the hidden input field
            });
            chip.appendChild(removeButton);
            dropdownInput.insertBefore(chip, dropdownInput.querySelector('input'));
            document.getElementById('howDidYouHear').value = option; // Update the value of the hidden input field
            toggleDropdown();
        }

        function filterSkills() {
            const input = document.querySelector('.dropdown-input input').value.toLowerCase();
            const dropdownOptions = document.querySelectorAll('.dropdown-item');
            dropdownOptions.forEach(option => {
                const value = option.textContent.toLowerCase();
                if (value.includes(input)) {
                    option.style.display = 'block';
                } else {
                    option.style.display = 'none';
                }
            });
        }
    </script>



  @if (TempData["LastPage"] != null && (int)TempData["LastPage"] > 1)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const currentPage = @TempData["LastPage"];
        const jobUid = '@TempData["JobUid"]';

        const jobPages = {
            1: { name: "Organization", action: "Retrieve", controller: "JobPost", emoji: "🏢" },
            2: { name: "Basics", action: "JobBasics", controller: "JobPost", emoji: "📝" },
            3: { name: "Details", action: "JobDeatils", controller: "JobPost", emoji: "📑" },
            4: { name: "Pay & Benefits", action: "PayBenefits", controller: "JobDetails", emoji: "💰" },
            5: { name: "Description", action: "JobDescription", controller: "JobDetails", emoji: "🖋️" },
            6: { name: "Preferences", action: "JobPreferences", controller: "JobDetails", emoji: "⚙️" },
            7: { name: "Review", action: "Review", controller: "JobReview", emoji: "🔍" },
            8: { name: "Qualifications", action: "Qualifications", controller: "JobReview", emoji: "🎓" }
        };

        function getPageUrl(pageNumber) {
            const page = jobPages[pageNumber];
            if (!page) return '@Url.Action("Retrieve", "JobPost")';
            return '@Url.Action("__ACTION__", "__CONTROLLER__", new { jobUid = "__JOBUID__" })'
                .replace("__ACTION__", page.action)
                .replace("__CONTROLLER__", page.controller)
                .replace("__JOBUID__", jobUid);
        }

        document.addEventListener("DOMContentLoaded", function () {
            if (currentPage > 1) {
                showIndeedAlert(currentPage);
            }
        });

        function showIndeedAlert(pageNumber) {
            const page = jobPages[pageNumber] || jobPages[1];
            const screenWidth = window.innerWidth;
            const alertWidth = screenWidth <= 480 ? '90vw' : screenWidth <= 768 ? '85vw' : '500px';
            const alertPadding = screenWidth <= 480 ? '1.5rem' : '2rem';
            const titleSize = screenWidth <= 480 ? '20px' : '24px';
            const contentSize = screenWidth <= 480 ? '14px' : '15px';

            Swal.fire({
                title: 'Resume your job posting?',
                html: `
                    <div style="text-align: center;">
                        <div style="font-size: ${screenWidth <= 480 ? '40px' : '48px'}; color: #2557a7; margin-bottom: ${screenWidth <= 480 ? '12px' : '16px'};">${page.emoji}</div>
                        <p style="color: #666;font-weight:600; margin-bottom: ${screenWidth <= 480 ? '6px' : '8px'}; font-size: ${contentSize};">You were working on:</p>
                        <div style="background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%); padding: ${screenWidth <= 480 ? '10px' : '12px'}; border-radius: ${screenWidth <= 480 ? '4px' : '6px'}; margin: ${screenWidth <= 480 ? '12px' : '16px'} 0; border-left: ${screenWidth <= 480 ? '3px' : '4px'} solid #2557a7;">
                            <strong style="color: #2557a7; font-size: ${screenWidth <= 480 ? '15px' : '16px'};">Page ${pageNumber}: ${page.name}</strong>
                        </div>
                        <p style="color: #666; font-size: ${contentSize}; line-height: 1.5; font-weight:600;">Would you like to continue where you left off?</p>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'Continue',
                cancelButtonText: 'Start Over',
                allowOutsideClick: false,
                width: alertWidth,
                padding: alertPadding,
                customClass: {
                    popup: 'indeed-swal',
                    title: 'indeed-title',
                    htmlContainer: 'indeed-content',
                    confirmButton: 'indeed-confirm-btn',
                    cancelButton: 'indeed-cancel-btn',
                    actions: 'indeed-actions'
                },
                buttonsStyling: false,
                backdrop: screenWidth <= 768 ? true : 'rgba(0,0,0,0.4)'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = getPageUrl(pageNumber);
                } else {
                    fetch('@Url.Action("SoftDeleteDraft", "JobPost")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ jobUid: jobUid })
                    })
                    .finally(() => {
                        window.location.href = '@Url.Action("Retrieve", "JobPost")';
                    });
                }
            });
            const style = document.createElement('style');
            style.textContent = `
                .indeed-swal { border-radius: ${screenWidth <= 480 ? '12px' : '16px'} !important; border: 1px solid #e0e0e0 !important; box-shadow: 0 ${screenWidth <= 480 ? '8px' : '12px'} ${screenWidth <= 480 ? '24px' : '32px'} rgba(0, 0, 0, 0.15) !important; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif !important; overflow: hidden !important; max-width: ${screenWidth <= 480 ? '95%' : 'none'} !important; margin: ${screenWidth <= 480 ? '10px' : '0'} !important; }
                .indeed-title { color: #000 !important; font-weight: 600 !important; font-size: ${titleSize} !important; margin-bottom: 0 !important; line-height: 1.3 !important; }
                .indeed-content { padding: 8px 0 0 0 !important; color: #333 !important; font-size: ${contentSize} !important; line-height: 1.5 !important; }
                .indeed-confirm-btn { background: #2557a7 !important; color: white !important; border: none !important; padding: ${screenWidth <= 480 ? '10px 16px' : '12px 24px'} !important; border-radius: ${screenWidth <= 480 ? '6px' : '8px'} !important; font-size: ${screenWidth <= 480 ? '14px' : '15px'} !important; font-weight: bold !important; width: ${screenWidth <= 480 ? '100%' : 'auto'} !important; }
                .indeed-cancel-btn { background: #999 !important; color: white !important; border: none !important; padding: ${screenWidth <= 480 ? '10px 16px' : '12px 24px'} !important; border-radius: ${screenWidth <= 480 ? '6px' : '8px'} !important; font-size: ${screenWidth <= 480 ? '14px' : '15px'} !important; font-weight: bold !important; width: ${screenWidth <= 480 ? '100%' : 'auto'} !important; }
                .indeed-actions { margin-top: ${screenWidth <= 480 ? '20px' : '24px'} !important; gap: ${screenWidth <= 480 ? '10px' : '12px'} !important; flex-direction: ${screenWidth <= 480 ? 'column' : 'row'} !important; }
                .swal2-timer-progress-bar { background: #2557a7 !important; height: 3px !important; }
            `;
            document.head.appendChild(style);
        }
    </script>
}







</body>

</html>