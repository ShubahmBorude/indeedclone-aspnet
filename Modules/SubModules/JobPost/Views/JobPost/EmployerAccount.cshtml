    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <!-- jquery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- ionicons -->
    <script type="module" src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.js"></script>

   
</head>



<body>

<!-- Flash Messages -->
<div class="flash-messages-container">
    @if (TempData["Success"] != null)
    {
         <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                    <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                     <span>@Html.Raw(TempData["Success"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
     }

    @if (TempData["Error"] != null)
    {
         <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                     <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </svg>
                      <span>@Html.Raw(TempData["Error"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
         </div>
     }
</div>

<!-- The Form -->
<form id="employerForm" method="post" action="@Url.Action("updateOrganization", "JobPost", new {jobUid = Model.JobUid, returnToReview = ViewContext.HttpContext.Request.Query["returnToReview"].FirstOrDefault()?.ToLower() == "true" })">
   @Html.AntiForgeryToken()
    <div class="image-container">
        <h1>Create an employer account</h1>
    </div>

    <small style="font-size: 18px;">
        If you have previously posted a job, please log in to your employer account to access the dashboard.
        <a href="" class="d-inline-flex align-items-center text-decoration-none">
            <span style="color: #377dff; font-weight: 600; text-decoration: none;" class="me-1">Employer Dashboard</span>
            <ion-icon name="open-outline"></ion-icon>
        </a>
    </small>

    <!-- Custom Divider -->
    <div class="custom-divider"></div>

    <div class="form-group">
        <label for="companyName">Company Name *</label>
        <input type="text" id="companyName" name="CompanyName" value="@Model.CompanyName" placeholder="Enter your company name">
    </div>

    <div class="form-group">
        <label for="gstinNumber">GSTIN Number *</label>
        <input type="text" id="gstinNumber" name="GstinNumber" value="@Model.GstinNumber" placeholder="Enter 15 digits GSTIN number">
    </div>

    <div class="form-group">
        <label for="fullName">First & Last Name *</label>
        <input type="text" id="fullName" name="FullName" value="@Model.FullName" placeholder="Enter your full name">
    </div>

   <div class="form-group">
     <label for="gstinNumber">How did you hear about us? *</label>
      <select id="howDidYouHear" name="ReferralSource" class="custom-dropdown">
        <option value="" disabled style="color:rgba(48, 48, 49, 0.48);">Select an option</option>
            @foreach (ReferralSource source in Enum.GetValues(typeof(ReferralSource)))
            {
                var displayName = source
                    .GetType()
                    .GetMember(source.ToString())
                    .First()
                    .GetCustomAttribute<DisplayAttribute>()?.Name ?? source.ToString();

                <option value="@source" @(Model.ReferralSource == source ? "selected" : "")>
                    @displayName
                </option>
            }
    </select>
  </div>


    <div class="form-group mb-5">
        <label for="contactInfo">Phone No *</label>
        <div class="phone-input">
            <div class="flag">
                <img src="https://flagcdn.com/in.svg" alt="Indian Flag">
                <span>+91</span>
            </div>
            <input type="tel" id="contactInfo" name="MobileNumber" value="@Model.MobileNumber" placeholder="Enter your contact number" 
                   pattern="[0-9]{10}" maxlength="10">
        </div>
        <small class="text-muted" style="display: block; margin-top: 0.25rem;">Enter 10-digit phone number</small>
    </div>

    <!-- Custom Divider -->
    <div class="custom-divider"></div>

    <div class="mb-5 d-flex justify-content-center justify-content-md-end">
        <button class="btn btn-lg" type="submit">
            <div class="d-flex align-items-center justify-content-center">
                <span>Continue</span>
            </div>
        </button>
    </div>
</form>

    

   
