@inject IConfiguration Configuration
@model IndeedClone.Modules.SubModules.Auth.DTO.VerifyEmailViewDTO
@{
    Layout = "_AuthNavbarLayout";
    ViewData["Title"] = "Verify Email";
 }


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0">

    <!-- Fav Icon -->
    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"] - IndeedClone </title>


    <!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">
    
    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/auth/custom-auth.css" />    
    <link rel="stylesheet" href="~/css/errors/error.css" />    

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <!-- jquery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- ionicons -->
    <script type="module" src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://cdn.jsdelivr.net/npm/ionicons@latest/dist/ionicons/ionicons.js"></script>
   
</head>

<body>

       <!-- Container -->
       <div class="container py-4 py-sm-4">
         <div class="container py-5 py-sm-7 mb-0 pb-0">
             
             <!-- Flash Messages -->
            <div class="flash-messages-container">
                @if (TempData["Success"] != null)
                {
                     <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <div class="flash-content">
                            <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                                <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                            </svg>
                                 <span>@Html.Raw(TempData["Success"])</span>
                        </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                      </div>
                 }

                @if (TempData["Error"] != null)
                {
                     <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <div class="flash-content">
                            <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                                 <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                            </svg>
                                  <span>@Html.Raw(TempData["Error"])</span>
                        </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                     </div>
                 }
            </div>

            <div class="mx-auto" style="max-width: 24rem;">
                <div class="card card-lg mb-5 shadow p-3 mb-5 bg-white border-0 rounded-1">
                    <div class="card-body mt-0 mb-0 pb-0 pt-0">
                        <div class="row justify-content-center mt-0 mb-0 pb-0 pt-0">
                            <div class="w-100 content-space-t-4 content-space-t-lg-2 content-space-b-1 mt-0 mb-0 pb-0 pt-0" style="max-width: 20rem;">

                                <!-- OTP Image GIF -->
                                    <div class="mt-3 mb-3 d-flex justify-content-center mr-7 pr-7">
                                        <img class="avatar avatar-xxl bg-grey avatar-4x3 ml-6 pl-6" src="~/gif/account-recovery-sms-pin.gif" alt="Image Description" data-hs-theme-appearance="dark" style="widht:114px; height: 114px;">
                                    </div>

                                    <!-- Title -->
                                    <div class="text-center">
                                        <div class="mb-3">
                                            <h4 class style='font-family:  -apple-system, BlinkMacSystemFont, " Segoe UI", Roboto, Helvetica, Arial, sans-serif; font-size: 1.5rem; line-height: 3.2rem; font-weight: 900;'>2-step Verification</h4>
                                            <p class=" text-muted" style='font-family: -apple-system, BlinkMacSystemFont, " Segoe UI", Roboto, Helvetica, Arial, sans-serif;'>We sent a verification code to your email.</p>
                                            <p class=" text-muted" style="font-family: 'Google Sans', Roboto, 'Noto Sans Myanmar UI', Arial, sans-serif;">Enter the code from the email in the field below.</p>
                                        </div>
                                    </div>

                                    <form id="login" class="js-validate needs-validation" action="@Url.Action("VerifyResetOTP", "ResetPassword", new { refNo = Model.EncryptedRefNo } )" method="post">
                                         @Html.AntiForgeryToken()

                                        <input type="hidden" name="otp" id="otpFull" />

                                        <div class="row gx-2 gx-sm-3 ">
                                            <div class="col">
                                                <div class="mb-4">
                                                    <input type="text" class="form-control form-control-single-number text-center" name="code1" id="twoStepVerificationSrCodeInput1" placeholder="" aria-label="" maxlength="1" autocomplete="off" autocapitalize="off" spellcheck="false" autofocus="">
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="mb-4">
                                                    <input type="text" class="form-control form-control-single-number text-center" name="code2" id="twoStepVerificationSrCodeInput2" placeholder="" aria-label="" maxlength="1" autocomplete="off" autocapitalize="off" spellcheck="false">
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="mb-4">
                                                    <input type="text" class="form-control form-control-single-number text-center" name="code3" id="twoStepVerificationSrCodeInput3" placeholder="" aria-label="" maxlength="1" autocomplete="off" autocapitalize="off" spellcheck="false">
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="mb-4">
                                                    <input type="text" class="form-control form-control-single-number text-center" name="code4" id="twoStepVerificationSrCodeInput4" placeholder="" aria-label="" maxlength="1" autocomplete="off" autocapitalize="off" spellcheck="false">
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Button -->
                                        <div class="d-grid gap-2 mb-1">
                                            <button type="submit" class="btn btn-white btn-md rounded-1" style='font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; font-weight: 600; background-color: rgb(37, 90, 168); color: white; padding: 9px'>Verify your account</button>
                                        </div>
                                    </form>

                                    <!-- Resend OTP -->
                                    <div class="text-center mb-2 pb-0">
                                        <form method="post" action="@Url.Action("ResendOtp", "Register", new { refNo = Model.EncryptedRefNo })">
                                         @Html.AntiForgeryToken()
                                        <p style='font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; color: rgb(93, 107, 123);'>Haven't received it?
                                            <button id="resend-code" 
                                                    type="submit"
                                                    style="text-decoration:none; border: none; background-color: transparent;">

                                                <strong style='font-family: RobotoDraft, Helvetica, Arial, sans-serif; color: rgb(37, 90, 168); text-decoration: none;'>
                                                    Resend new code
                                                </strong>
                                            </button>
                                        </p>
                                        </form>
                                    </div>

                                    <!-- Timer -->
                                    <div id="timer" class="text-center mt-3" style='font-family: "Google Sans", roboto, "Noto Sans Myanmar UI", arial, sans-serif;color: rgb(93, 107, 123);'>
                                        Time remaining: <span id="countdown" style='font-family: "Google Sans", roboto, "Noto Sans Myanmar UI", arial, sans-serif;color:rgb(58, 66, 74);'>15:00</span> minutes
                                    </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    
     <script>
        document.getElementById("login").addEventListener("submit", function () {
        const otp =
            document.querySelector('[name="code1"]').value +
            document.querySelector('[name="code2"]').value +
            document.querySelector('[name="code3"]').value +
            document.querySelector('[name="code4"]').value;
        document.getElementById("otpFull").value = otp;
    });
    </script>


    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const otpInputs = document.querySelectorAll('.form-control-single-number');
            otpInputs.forEach((input, index) => {
                input.addEventListener('input', function(e) {
                    if (this.value.length === 1) {
                        if (index < otpInputs.length - 1) {
                            otpInputs[index + 1].focus();
                        }
                    }
                });
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Backspace' && this.value.length === 0) {
                        if (index > 0) {
                            otpInputs[index - 1].focus();
                        }
                    }
                });
            });
        });
    </script>

    <script>
        function showSpinner() {
            var spinner = document.getElementById("spinner");
            spinner.style.display = "flex";
            setTimeout(function() {
                spinner.style.display = "none";
            }, 6000);
        }
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const timerElement = document.getElementById('countdown');
            const timerContainer = document.getElementById('timer');
            const resendButton = document.getElementById('resend-code');
            const totalTime = 15 * 60;
            const storageKey = 'timerStartTime';
            let interval;
            const startTimer = () => {
                if (!localStorage.getItem(storageKey)) {
                    const startTime = Math.floor(Date.now() / 1000);
                    localStorage.setItem(storageKey, startTime.toString());
                }
                const updateTimer = () => {
                    const currentTime = Math.floor(Date.now() / 1000);
                    const storedStartTime = parseInt(localStorage.getItem(storageKey), 10);
                    const elapsedTime = currentTime - storedStartTime;
                    const remainingTime = totalTime - elapsedTime;

                    if (remainingTime > 0) {
                        const minutes = Math.floor(remainingTime / 60);
                        const seconds = remainingTime % 60;
                        timerElement.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                        timerElement.style.color = remainingTime <= 300 ? 'rgb(179, 38, 30)' : '';
                    } else {
                        clearInterval(interval);
                        timerContainer.textContent = 'Your code has expired';
                        timerContainer.style.color = 'rgb(179, 38, 30)';
                        localStorage.removeItem(storageKey);
                    }
                };
                clearInterval(interval);
                updateTimer();
                interval = setInterval(updateTimer, 1000);
            };
            if (localStorage.getItem(storageKey)) {
                startTimer();
            } else {
                localStorage.setItem(storageKey, Math.floor(Date.now() / 1000).toString());
                startTimer();
            }
            resendButton.addEventListener('click', function(e) {
                e.preventDefault();
                localStorage.setItem(storageKey, Math.floor(Date.now() / 1000).toString());
                startTimer();
                setTimeout(function() {
                    window.location.href = resendButton.href;
                }, 500);
            });
        });
    </script>

</body>
</html>





                