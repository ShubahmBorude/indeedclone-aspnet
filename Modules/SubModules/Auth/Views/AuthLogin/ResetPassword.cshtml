
@{
    Layout = "_AuthNavbarLayout";
    ViewData["Title"] = "Reset Password";
 }
    @inject IConfiguration Configuration



<!DOCTYPE html>
<html lang="en">
<head>
    
     <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"] - IndeedClone</title>

     <!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">
    
    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>


    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/auth/custom-auth.css" />
    <link rel="stylesheet" href="~/css/errors/error.css" />    

</head>


<body>

  
    <!-- Container -->
      <div class="container py-4 py-sm-4">
         <div class="container py-5 py-sm-7 mb-0 pb-0">
           
            <!-- Flash Messages -->
            <div class="flash-messages-container">
                @if (TempData["Success"] != null)
                {
                     <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <div class="flash-content">
                            <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                                <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                            </svg>
                                 <span>@Html.Raw(TempData["Success"])</span>
                        </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                      </div>
                 }

                @if (TempData["Error"] != null)
                {
                     <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <div class="flash-content">
                            <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                                 <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                            </svg>
                                  <span>@Html.Raw(TempData["Error"])</span>
                        </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                     </div>
                 }
            </div>

            <div class="mx-auto" style="max-width: 30rem;">
                <div class="card card-lg mb-5 shadow p-3 mb-5 bg-white border-0 rounded-1">
                    <div class="card-body mt-0 mb-0 pb-0 pt-0">
                        <div class="row justify-content-center mt-0 mb-0 pb-0 pt-0">
                            <div class="w-100 content-space-t-4 content-space-t-lg-2 content-space-b-1 mt-0 mb-0 pb-0 pt-0" style="max-width: 25rem;">


                                <!-- Form -->
                                <form id="login" class="js-validate needs-validation" method="post" action="@Url.Action("ForgotPassword", "ResetPassword")" novalidate> 
                                    @Html.AntiForgeryToken()
                                    <div class="text-center">
                                        <div class="mb-4">
                                            <h2 class="display-6" style="font-size: 1.8rem; line-height: 3.2rem; font-weight: 900;color: rgb(58, 66, 74);">Reset Password</h2>
                                        </div>
                                            <p>Enter your email address and we'll send you instructions to reset your password.</p>
                                    </div>
                                   
                                    <!-- Email or Phone No -->
                                    <div class="mb-3 input-container">
                                        <div class="input-wrapper">
                                            <input type="email" class="js-toggle-password form-control form-control-lg rounded-1" name="email" id="signinSrEmail" tabindex="1" placeholder=" " required>
                                            <label class="form-label" for="email">Email address</label>
                                        </div>
                                    </div>

                                 
                                    <!--  Send reset link -->
                                    <div class="d-grid gap-2 mb-2">
                                        <button type="submit" class="btn btn-white btn-md rounded-1" style=' font-weight: 600; background-color: rgb(37, 90, 168); color: white; padding: 9px;'>
                                            <i class="bi bi-envelope-fill me-2"></i>
                                            Send reset link
                                        </button>
                                    </div>

                                </form>

                                    <div class="text-center mb-1">
                                        <a class="btn btn-link" href="@Url.Action("Login", "Auth")" style="font-size: 0.875rem; text-decoration: none;"><i class="bi-chevron-left" style="position: relative; top: -1px;color: rgb(37, 90, 168);"></i><strong style='color: rgb(37, 90, 168);'> Skip or Back to Login</strong></a>
                                    </div>

                               
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            @*  <div class="text-center mt-4">
                <p class="text-muted">Need help? <a href="#" class="text-decoration-none">Contact Support</a></p>
            </div> *@
        </div>
    </div>



</body>
</html>