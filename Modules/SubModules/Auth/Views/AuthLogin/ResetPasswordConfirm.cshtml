@inject IConfiguration Configuration
@model IndeedClone.Modules.SubModules.Auth.DTO.VerifyEmailViewDTO
@{
    Layout = "_AuthNavbarLayout";
    ViewData["Title"] = "Reset Password Confirm";
 }


<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"] - IndeedClone</title>

<!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/auth/custom-auth.css" />
    <link rel="stylesheet" href="~/css/errors/error.css" />    

</head>

<body>


    <div class="container py-5 py-sm-7">
        <div class="container py-5 py-sm-7 mb-0 pb-0">
            
            <!-- Flash Messages -->
            <div class="flash-messages-container">
                @if (TempData["Success"] != null)
                {
                     <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <div class="flash-content">
                            <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                                <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                            </svg>
                                 <span>@Html.Raw(TempData["Success"])</span>
                        </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                      </div>
                 }

                @if (TempData["Error"] != null)
                {
                     <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <div class="flash-content">
                            <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                                 <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                            </svg>
                                  <span>@Html.Raw(TempData["Error"])</span>
                        </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                     </div>
                 }
            </div>

            <div class="mx-auto" style="max-width: 23rem;">
                <div class="card card-lg mb-5 shadow p-3 mb-5 bg-white border-0 rounded-1">
                    <div class="card-body mt-0 mb-0 pb-0 pt-0">
                        <div class="row justify-content-center mt-0 mb-0 pb-0 pt-0">
                            <div class="w-100 content-space-t-4 content-space-t-lg-2 content-space-b-1 mt-0 mb-0 pb-0 pt-0" style="max-width: 20rem;">

                                <!-- Form -->
                                <form id="login" method="post" action="@Url.Action("UpdateNewPassword", "ResetPassword", new { refNo = Model.EncryptedRefNo })" class="js-validate needs-validation " novalidate>

                                    <div class="text-center">
                                        <div class="mb-3">
                                            <h4 class style='font-size: 1.5rem; line-height: 3.2rem; font-weight: 900;'>Reset Password?</h4>
                                            <p class="text-muted text-inline ml-0 mr-0 pr-0 pl-0">please enter correct email address associated with your account to reset your password</p>
                                        </div>
                                    </div>

                                    <input type="hidden" name="token" value="@ViewData["Token"]" />

                                    <!-- new password -->
                                    <div class="mb-3 input-container">
                                        <div class="input-wrapper">
                                            <input type="password" class="c js-toggle-password form-control form-control-lg rounded-1" name="password" value="" id="password" placeholder=" " aria-label="*************" autocomplete="new-password" data-msg="Invalid Password Entered. Please try again."
                                                data-hs-toggle-password-options="{
                                                        &quot;target&quot;: &quot;#changePassTarget&quot;,
                                                        &quot;defaultClass&quot;: &quot;tio-hidden-outlined&quot;,
                                                        &quot;showClass&quot;: &quot;tio-visible-outlined&quot;,
                                                        &quot;classChangeTarget&quot;: &quot;#changePassIcon1&quot;
                                                    }">
                                            <label class="form-label" for="password">New Password</label>
                                            <!-- Show Password Toggle -->
                                            <span class="input-group-text toggle-password" id="togglePassword1">
                                                <!-- <i class="bi bi-eye-slash" id="changePassIcon1"></i> -->
                                            </span>
                                        </div>
                                        <span class="invalid-feedback">Please enter a valid password.</span>
                                    </div>

                                    <!-- Confirm Password -->
                                    <div class="mb-4 input-container">
                                        <div class="input-wrapper">
                                            <input type="confirmPassword" class="c js-toggle-password form-control form-control-lg rounded-1" name="confirmPassword" value="" id="confirmPassword" placeholder=" " aria-label="*************" autocomplete="new-password" data-msg="Invalid Password Entered. Please try again."
                                                data-hs-toggle-password-options="{
                                                    &quot;target&quot;: &quot;#changePassTarget&quot;,
                                                    &quot;defaultClass&quot;: &quot;tio-hidden-outlined&quot;,
                                                    &quot;showClass&quot;: &quot;tio-visible-outlined&quot;,
                                                    &quot;classChangeTarget&quot;: &quot;#changePassIcon2&quot;
                                                }">
                                            <label class="form-label" for="confirmPassword">Confirm Password</label>
                                            <!-- Show Password Toggle -->
                                            <span class="input-group-text toggle-password" id="togglePassword2">
                                                <!-- <i class="bi bi-eye-slash" id="changePassIcon2"></i> -->
                                            </span>
                                        </div>
                                        <span class="invalid-feedback">Please enter a valid password.</span>
                                    </div>

                                    <!-- submit button -->
                                    <div class="d-grid gap-2 mb-1">
                                        <button type="submit" class="btn btn-white btn-md rounded-1" style='font-weight: 600; background-color: rgb(11 87 208 / 1); color: white; padding: 9px;'>Submit</button>
                                    </div>

                                </form>

                                <!-- sign in or sign up -->
                                <div class="text-center mb-1">
                                    <a class="btn btn-link" href="@Url.Action("Login", "Auth")" style="font-size: 0.875rem; text-decoration: none;"><i class="bi-chevron-left" style="position: relative; top: -1px;color: rgb(11, 87, 208);"></i><strong style='color: rgb(11, 87, 208);'> Skip or Back to Login</strong></a>
                                </div>



                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



    <script>

        document.addEventListener('DOMContentLoaded', function() {
            // Function to toggle password visibility
            function togglePasswordVisibility(inputId, iconId) {
                const passwordInput = document.querySelector(inputId);
                const changePassIcon = document.querySelector(iconId);

                if (passwordInput && changePassIcon) {
                    // Toggle password visibility
                    passwordInput.type = passwordInput.type === 'password' ? 'text' : 'password';
                    // Toggle the eye icon
                    changePassIcon.classList.toggle('bi-eye');
                    changePassIcon.classList.toggle('bi-eye-slash');
                }
            }

            // Add event listeners for both password fields
            document.querySelector('#togglePassword1').addEventListener('click', function() {
                togglePasswordVisibility('#password', '#changePassIcon1');
            });

            document.querySelector('#togglePassword2').addEventListener('click', function() {
                togglePasswordVisibility('#confirmPassword', '#changePassIcon2');
            });
        });
    </script>

   
</body>