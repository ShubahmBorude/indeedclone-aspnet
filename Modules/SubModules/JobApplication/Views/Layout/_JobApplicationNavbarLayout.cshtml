@inject IConfiguration Configuration
@inject IHttpContextAccessor HttpContextAccessor

@{
    // var session = HttpContextAccessor.HttpContext.Session;
    var logoUrl = Configuration["Branding:Logo"];
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var showDashboard = (controller == "JobPost" && action == "Retrieve");

    string userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "No email available";

 // # Get current controller and action for active link detection
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    
 // # Helper function to check if link is active
    bool IsActive(string controller, string action = null)
    {
        if (action == null)
            return currentController == controller;

        return currentController == controller && currentAction == action;
    }
}

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0">

    <!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- custom css -->
    <link rel="stylesheet" href="~/css/app-home/indeedhomenavabrlayout.css">

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <style> body{ padding : 0 !important;  margin: 0 !important; } </style>
</head>

<body>

     <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light" style="height: 81px;">
        <div class="container-fluid">
            <!-- Brand/Logo -->
            <a class="navbar-brand me-3" href="@Url.Action("Retrieve", "IndeedClone")">
                <div class="d-flex align-items-center">
                    <img src="@logoUrl" alt="Logo" style="height: 30px;">
                    <div class="mt-1" style="font-size:2.1rem; font-family:'Arial Rounded MT Bold', 'Nunito', sans-serif;color: #0A4299; font-weight: bold; letter-spacing: -2px !important;">clone</div> 
                </div>
            </a>
            
            <!-- Desktop Navigation -->
            <div class="collapse navbar-collapse" id="navbarContent">
                <!-- Left Navigation Links -->
                <ul class="navbar-nav me-auto mb-2 mt-3 mb-lg-0">
                    <li class="nav-item me-1">
                        <a class="nav-link active" aria-current="page" href="@Url.Action("Retrieve", "IndeedClone")">Home</a>
                    </li>
                    <li class="nav-item me-1">
                        <a class="nav-link" href="@Url.Action("CompanyReviews", "IndeedClone")">Company Reviews</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Salaries", "IndeedClone")">Salaries</a>
                    </li>
                </ul>

                    <!-- User Info -->
                    <ul class="navbar-nav mb-2 mb-lg-0 mt-3">
                        <li class="nav-item">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-person-fill me-2"></i>
                                <span class="mt-1">@userEmail</span>
                            </div>
                        </li>
                    </ul>
                </div>

                <!-- Mobile Toggle Button (visible only on mobile) -->
              <button class="navbar-toggler d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileNavbar" aria-controls="mobileNavbar">
                   <span class="navbar-toggler-icon"></span>
              </button>
        </div>
    </nav>

    <!-- Mobile Offcanvas Sidebar -->
    <div class="offcanvas offcanvas-end d-lg-none" tabindex="-1" id="mobileNavbar" aria-labelledby="mobileNavbarLabel">
        <div class="offcanvas-header border-bottom">
            <div class="d-flex align-items-center">
                <img src="@logoUrl" alt="Logo" style="height: 30px;" />
                <div class="mt-1" style="font-size:2.1rem; font-family:'Arial Rounded MT Bold', 'Nunito', sans-serif;color: #0A4299; font-weight: bold; letter-spacing: -2px !important;">clone</div> 
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
            <div class="offcanvas-body">
                <!-- User Info on Mobile -->
                <div class="d-flex align-items-center mb-4 p-3 bg-light rounded">
                    <i class="bi bi-person-fill me-3 fs-5"></i>
                    <div>
                        <div class="fw-bold">@userEmail</div>
                        <small class="text-muted">User Account</small>
                    </div>
                </div>
                     
                  <!-- Main Navigation -->
                <div class="sidebar-section">
                    <h6 class="sidebar-section-title">Navigation</h6>
                    <ul class="sidebar-nav">
                        <li class="sidebar-nav-item">
                            <a href="@Url.Action("Retrieve", "IndeedClone")" class="sidebar-nav-link @(IsActive("IndeedClone", "Retrieve") ? "active" : "")">
                                <span class="sidebar-nav-icon"><i class="bi bi-house-door"></i></span>
                                Home
                            </a>
                        </li>
                        <li class="sidebar-nav-item">
                            <a href="@Url.Action("CompanyReviews", "IndeedClone")" class="sidebar-nav-link @(IsActive("IndeedClone", "CompanyReviews") ? "active" : "")">
                                <span class="sidebar-nav-icon"><i class="bi bi-building"></i></span>
                                Company Reviews
                            </a>
                        </li>
                        <li class="sidebar-nav-item">
                            <a href="@Url.Action("Salaries", "IndeedClone")" class="sidebar-nav-link @(IsActive("IndeedClone", "Salaries") ? "active" : "")">
                                <span class="sidebar-nav-icon"><i class="bi bi-cash-stack"></i></span>
                                Salaries
                            </a>
                        </li>
                         <li class="sidebar-nav-item">
                            <a href="@Url.Action("Retrieve", "JobDashboard")" class="sidebar-nav-link @(IsActive("JobDashboard", "Retrieve") ? "active" : "")">
                                <span class="sidebar-nav-icon"><i class="bi bi-speedometer2"></i></span>
                                Job Dashboard
                            </a>
                        </li>
                    </ul>
                </div>

                   <!-- Account Section -->
        <div class="sidebar-section">
            <h6 class="sidebar-section-title">Account</h6>
            <ul class="sidebar-nav">
                <li class="sidebar-nav-item">
                    <a href="#" class="sidebar-nav-link">
                        <span class="sidebar-nav-icon"><i class="bi bi-chat-left-text"></i></span>
                        Messages
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a href="#" class="sidebar-nav-link">
                        <span class="sidebar-nav-icon"><i class="bi bi-bell"></i></span>
                        Notifications
                        <span class="badge bg-danger ms-auto">3</span>
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a href="#" class="sidebar-nav-link">
                        <span class="sidebar-nav-icon"><i class="bi bi-person"></i></span>
                        Profile & Account
                    </a>
                </li>
                <li class="sidebar-nav-item">
                    <a href="#" class="sidebar-nav-link">
                        <span class="sidebar-nav-icon"><i class="bi bi-gear"></i></span>
                        Settings
                    </a>
                </li>
            </ul>
        </div>

                    <!-- Sign In/Out Section -->
                    <div class="sidebar-section mt-4">
                       <form method="post" action="@Url.Action("Logout", "Auth")" class="m-0">
                                @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-primary w-100 mb-2">Sign out</button>
                        </form>  
                    </div>

               </div>
         </div>

                   @RenderBody()     

</body>
</html>