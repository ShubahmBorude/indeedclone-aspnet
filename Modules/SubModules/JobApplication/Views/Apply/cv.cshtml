@* @using System.IO *@
@model IndeedClone.Modules.SubModules.JobApplication.DTO.CVDTO
@{
    Layout = "_JobApplicationNavbarLayout";
    ViewData["Title"] = " Add CV - IndeedClone";

    bool hasCV = !string.IsNullOrWhiteSpace(Model.FileName);
    var fileExt = System.IO.Path.GetExtension(Model.FileName)?.ToLower();
}

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0">

    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- custom css -->
    <link rel="stylesheet" href="~/css/job-application/cv.css">
    <link rel="stylesheet" href="~/css/errors/error.css" />    

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <style> body{ padding : 0 !important;  margin: 0 !important; } </style>
</head>

<body>



<!-- Flash Messages -->
<div class="flash-messages-container">
    @if (TempData["Success"] != null)
    {
         <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                    <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                     <span>@Html.Raw(TempData["Success"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
     }

    @if (TempData["Error"] != null)
    {
         <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                     <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </svg>
                      <span>@Html.Raw(TempData["Error"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
         </div>
     }
</div>

 <div class="indeed-application-wrapper">
    <!-- Job Card - Indeed Style -->
    <div class="indeed-job-card">
        <div class="indeed-job-header">
            <h1 class="indeed-job-title">@Model.JobTitle</h1>
            <div class="indeed-company-info">
                <i class="bi bi-building"></i>
                <span>@Model.CompanyName</span>
                <span class="indeed-company-divider">•</span>
                <i class="bi bi-geo-alt"></i>
                <span>@Model.City, @Model.JobLocation</span>
            </div>
        </div>

        <h2 class="indeed-section-title">
            <i class="bi bi-file-earmark-text"></i>
            Submit your resume
        </h2>

        <form id="cv-upload-form" enctype="multipart/form-data" method="post" action="@Url.Action("UpdateCV", "JobApplication", new { applicationUid = Model.ApplicationUid, returnToReview = ViewContext.HttpContext.Request.Query["returnToReview"].FirstOrDefault()?.ToLower() == "true" })">
            @Html.AntiForgeryToken()     
            <!-- Hidden file input -->
            <input type="file" name="file" id="cv" style="display:none;" accept=".pdf,.docx" onchange="handleFileUpload(event)">

            @if (hasCV)
            {
                <!-- Existing CV Display - Indeed Style -->
                <div class="indeed-file-card">
                    <div class="indeed-file-header">
                        <div class="indeed-file-icon">
                            <i class="bi bi-file-earmark-pdf-fill"></i>
                        </div>
                        <div class="indeed-file-details">
                            <div class="indeed-file-name">@Model.FileName</div>
                            <div class="indeed-file-meta">
                                <span>Uploaded just now</span>
                                <span class="indeed-file-badge">
                                    <i class="bi bi-check-circle-fill"></i>
                                    Current Resume
                                </span>
                            </div>
                        </div>
                        <div class="indeed-file-actions">
                            <button type="button" class="indeed-file-action-btn" onclick="document.getElementById('cv').click()" title="Replace resume">
                                <i class="bi bi-arrow-repeat"></i>
                            </button>
                            <a href="@Url.Action("DownloadCV", "JobApplication", new { applicationUid = Model.ApplicationUid })" class="indeed-file-action-btn" title="Download">
                                <i class="bi bi-download"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Resume Preview - Indeed Style -->
                <div class="indeed-preview-card">
                    <div class="indeed-preview-header">
                        <h3>
                            <i class="bi bi-eye"></i>
                            Resume Preview
                        </h3>
                        <a href="@Url.Action("DownloadCV", "JobApplication", new { applicationUid = Model.ApplicationUid })" class="indeed-download-btn">
                            <i class="bi bi-file-earmark-arrow-down"></i>
                            Download
                        </a>
                    </div>
                    <div class="indeed-preview-body">
                        @if (fileExt == ".pdf")
                        {
                            <iframe class="indeed-preview-iframe" src="@Model.FilePath"></iframe>
                        }
                        else
                        {
                            <div class="indeed-preview-placeholder">
                                <i class="bi bi-file-earmark-text"></i>
                                <p>Preview not available for this file type</p>
                                <p style="font-size: 13px; margin-top: 8px;">Please download to view the content</p>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <!-- Upload Area - Indeed Style (No CV) -->
                <div class="indeed-cv-area" onclick="document.getElementById('cv').click()">
                    <div class="indeed-cv-icon">
                        <i class="bi bi-cloud-arrow-up"></i>
                    </div>
                    <div class="indeed-cv-title">Upload your resume</div>
                    <div class="indeed-cv-subtitle">Drag and drop or click to browse</div>
                    <div class="indeed-cv-formats">
                        <span><i class="bi bi-file-pdf"></i> PDF</span>
                        <span><i class="bi bi-file-word"></i> DOCX</span>
                        <span><i class="bi bi-hdd-stack"></i> Max 5MB</span>
                    </div>
                </div>
            }

            <!-- Dynamic Preview Container (for new uploads) -->
            <div id="resume-preview-container"></div>

            <!-- Continue Button -->
            <div class="indeed-mt-4">
                <button type="submit" class="indeed-btn-primary" id="continueBtn">
                    @(hasCV ? "Continue with this resume" : "Continue")
                </button>
            </div>
        </form>

        <!-- Alternative Options -->
        @if (hasCV)
        {
            <div class="indeed-text-center" style="margin-top: 16px;">
                <button type="button" class="indeed-btn-outline" onclick="document.getElementById('cv').click()">
                    <i class="bi bi-file-earmark"></i>
                    Browse files
                </button>
            </div>
        }
    </div>
</div>

<script>
    function handleFileUpload(event) {
        const file = event.target.files[0];
        if (!file) return;

        // Show file info immediately
        const container = document.getElementById('resume-preview-container');
        
        // Create file info card
        const fileSize = (file.size / (1024 * 1024)).toFixed(2); // Size in MB
        const fileExt = file.name.split('.').pop().toLowerCase();
        const iconClass = fileExt === 'pdf' ? 'bi-file-earmark-pdf-fill' : 'bi-file-earmark-word-fill';
        
        // Show file info card
        container.innerHTML = `
            <div class="indeed-file-card" style="margin-top: 16px; animation: cardFadeIn 0.3s ease-out;">
                <div class="indeed-file-header">
                    <div class="indeed-file-icon">
                        <i class="bi ${iconClass}"></i>
                    </div>
                    <div class="indeed-file-details">
                        <div class="indeed-file-name">${file.name}</div>
                        <div class="indeed-file-meta">
                            <span>${fileSize} MB</span>
                            <span class="indeed-file-badge">
                                <i class="bi bi-check-circle-fill"></i> Selected
                            </span>
                        </div>
                    </div>
                    <div class="indeed-file-actions">
                        <button type="button" class="indeed-file-action-btn" onclick="document.getElementById('cv').click(); this.closest('.indeed-file-card').remove();" title="Remove and select another">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>
            </div>
        `;

        // If PDF, show preview as well
        if (file.type === 'application/pdf') {
            const reader = new FileReader();
            reader.onload = function(e) {
                // Add preview after the file card
                const previewHTML = `
                    <div class="indeed-preview-card" style="margin-top: 16px; animation: cardFadeIn 0.3s ease-out;">
                        <div class="indeed-preview-header">
                            <h3>
                                <i class="bi bi-eye"></i>
                                Resume Preview
                            </h3>
                            <span class="indeed-file-badge">
                                <i class="bi bi-check-circle-fill"></i> Ready to upload
                            </span>
                        </div>
                        <div class="indeed-preview-body">
                            <iframe class="indeed-preview-iframe" src="${e.target.result}"></iframe>
                        </div>
                    </div>
                `;
                container.innerHTML += previewHTML;
            };
            reader.readAsDataURL(file);
        }

        // Enable continue button
        document.getElementById('continueBtn').disabled = false;
        
        // Add animation keyframes if not present
        if (!document.getElementById('animation-style')) {
            const style = document.createElement('style');
            style.id = 'animation-style';
            style.innerHTML = `
                @@keyframes cardFadeIn {
                    from {
                        opacity: 0;
                        transform: translateY(10px);
                    }
                    to {
                        opacity: 1;
                        transform: translateY(0);
                    }
                }
            `;
            document.head.appendChild(style);
        }
    }

    // Optional: Add drag and drop support
    document.addEventListener('DOMContentLoaded', function() {
        const cvArea = document.querySelector('.indeed-cv-area');
        if (cvArea) {
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                cvArea.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover'].forEach(eventName => {
                cvArea.addEventListener(eventName, highlight, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                cvArea.addEventListener(eventName, unhighlight, false);
            });

            function highlight() {
                cvArea.classList.add('indeed-cv-area-highlight');
                cvArea.style.borderColor = '#0a66c2';
                cvArea.style.backgroundColor = '#f4f9ff';
            }

            function unhighlight() {
                cvArea.classList.remove('indeed-cv-area-highlight');
                cvArea.style.borderColor = '#d1d7dc';
                cvArea.style.backgroundColor = '#fafcff';
            }

            cvArea.addEventListener('drop', handleDrop, false);

            function handleDrop(e) {
                const dt = e.dataTransfer;
                const files = dt.files;
                document.getElementById('cv').files = files;
                handleFileUpload({ target: { files: files } });
            }
        }
    });
</script>


    @if (TempData["LastPage"] != null && (int)TempData["LastPage"] > 1)
   {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const currentPage = @TempData["LastPage"];
        const applicationUid = '@TempData["ApplicationUid"]';

        const applicationPages = {
            1: { name: "CV", action: "CV", controller: "JobApplication", emoji: "📄" },
            2: { name: "Experience", action: "RelevantExperience", controller: "JobApplication", emoji: "💼" },
            3: { name: "Screener Questions", action: "ScreenerQuestions", controller: "JobApplication", emoji: "❓" },
            4: { name: "Review", action: "Review", controller: "JobApplication", emoji: "🔍" }
        };

        function getPageUrl(pageNumber) {
            const page = applicationPages[pageNumber];
            if (!page) return '@Url.Action("CV", "JobApplication")';
            return '@Url.Action("__ACTION__", "__CONTROLLER__", new { applicationUid = "__APPUID__" })'
                .replace("__ACTION__", page.action)
                .replace("__CONTROLLER__", page.controller)
                .replace("__APPUID__", applicationUid);
        }

        document.addEventListener("DOMContentLoaded", function () {
            if (currentPage > 1) {
                showIndeedAlert(currentPage);
            }
        });

        function showIndeedAlert(pageNumber) {
            const page = applicationPages[pageNumber] || applicationPages[1];
            const screenWidth = window.innerWidth;
            const alertWidth = screenWidth <= 480 ? '90vw' : screenWidth <= 768 ? '85vw' : '500px';
            const alertPadding = screenWidth <= 480 ? '1.5rem' : '2rem';
            const titleSize = screenWidth <= 480 ? '20px' : '24px';
            const contentSize = screenWidth <= 480 ? '14px' : '15px';

            Swal.fire({
                title: 'Resume your job application?',
                html: `
                    <div style="text-align: center;">
                        <div style="font-size: ${screenWidth <= 480 ? '40px' : '48px'}; color: #2557a7; margin-bottom: ${screenWidth <= 480 ? '12px' : '16px'};">${page.emoji}</div>
                        <p style="color: #666;font-weight:600; margin-bottom: ${screenWidth <= 480 ? '6px' : '8px'}; font-size: ${contentSize};">You were working on:</p>
                        <div style="background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%); padding: ${screenWidth <= 480 ? '10px' : '12px'}; border-radius: ${screenWidth <= 480 ? '4px' : '6px'}; margin: ${screenWidth <= 480 ? '12px' : '16px'} 0; border-left: ${screenWidth <= 480 ? '3px' : '4px'} solid #2557a7;">
                            <strong style="color: #2557a7; font-size: ${screenWidth <= 480 ? '15px' : '16px'};">Page ${pageNumber}: ${page.name}</strong>
                        </div>
                        <p style="color: #666; font-size: ${contentSize}; line-height: 1.5; font-weight:600;">Would you like to continue where you left off?</p>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'Continue',
                cancelButtonText: 'Start Over',
                allowOutsideClick: false,
                width: alertWidth,
                padding: alertPadding,
                customClass: {
                    popup: 'indeed-swal',
                    title: 'indeed-title',
                    htmlContainer: 'indeed-content',
                    confirmButton: 'indeed-confirm-btn',
                    cancelButton: 'indeed-cancel-btn',
                    actions: 'indeed-actions'
                },
                buttonsStyling: false,
                backdrop: screenWidth <= 768 ? true : 'rgba(0,0,0,0.4)'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = getPageUrl(pageNumber);
                } else {
                    fetch('@Url.Action("SoftDeleteDraft", "JobApplication")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ applicationUid: applicationUid })
                    })
                    .finally(() => {
                        window.location.href = '@Url.Action("CV", "JobApplication")';
                    });
                }
            });
            const style = document.createElement('style');
            style.textContent = `
                .indeed-swal { border-radius: ${screenWidth <= 480 ? '12px' : '16px'} !important; border: 1px solid #e0e0e0 !important; box-shadow: 0 ${screenWidth <= 480 ? '8px' : '12px'} ${screenWidth <= 480 ? '24px' : '32px'} rgba(0, 0, 0, 0.15) !important; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif !important; overflow: hidden !important; max-width: ${screenWidth <= 480 ? '95%' : 'none'} !important; margin: ${screenWidth <= 480 ? '10px' : '0'} !important; }
                .indeed-title { color: #000 !important; font-weight: 600 !important; font-size: ${titleSize} !important; margin-bottom: 0 !important; line-height: 1.3 !important; }
                .indeed-content { padding: 8px 0 0 0 !important; color: #333 !important; font-size: ${contentSize} !important; line-height: 1.5 !important; }
                .indeed-confirm-btn { background: #2557a7 !important; color: white !important; border: none !important; padding: ${screenWidth <= 480 ? '10px 16px' : '12px 24px'} !important; border-radius: ${screenWidth <= 480 ? '6px' : '8px'} !important; font-size: ${screenWidth <= 480 ? '14px' : '15px'} !important; font-weight: bold !important; width: ${screenWidth <= 480 ? '100%' : 'auto'} !important; }
                .indeed-cancel-btn { background: #999 !important; color: white !important; border: none !important; padding: ${screenWidth <= 480 ? '10px 16px' : '12px 24px'} !important; border-radius: ${screenWidth <= 480 ? '6px' : '8px'} !important; font-size: ${screenWidth <= 480 ? '14px' : '15px'} !important; font-weight: bold !important; width: ${screenWidth <= 480 ? '100%' : 'auto'} !important; }
                .indeed-actions { margin-top: ${screenWidth <= 480 ? '20px' : '24px'} !important; gap: ${screenWidth <= 480 ? '10px' : '12px'} !important; flex-direction: ${screenWidth <= 480 ? 'column' : 'row'} !important; }
                .swal2-timer-progress-bar { background: #2557a7 !important; height: 3px !important; }
            `;
            document.head.appendChild(style);
        }
    </script>
}


</body>
</html>