@using System.ComponentModel.DataAnnotations
@using System.Reflection
@using IndeedClone.Modules.SubModules.JobApplication.Enums
@model IndeedClone.Modules.SubModules.JobApplication.DTO.ScreenerQuestionsDTO
@{
    Layout = "_JobApplicationNavbarLayout";
    ViewData["Title"] = " Employee Screener Questions - IndeedClone";

 }

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0">

    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- custom css -->
    <link rel="stylesheet" href="~/css/job-application/empque.css">
    <link rel="stylesheet" href="~/css/errors/error.css" />    

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    @* <style> body{ padding : 0 !important;  margin: 0 !important; } </style> *@
</head>

<body>


<!-- Flash Messages -->
<div class="flash-messages-container">
    @if (TempData["Success"] != null)
    {
         <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                    <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                     <span>@Html.Raw(TempData["Success"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
     }

    @if (TempData["Error"] != null)
    {
         <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                     <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </svg>
                      <span>@Html.Raw(TempData["Error"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
         </div>
     }
</div>  
<!-- Main Content -->
<div class="container">
    <!-- Job Title Card - Indeed Style -->
    <div class="indeed-job-header-card">
        <h1 class="indeed-job-title">@Model.JobTitle</h1>
        <div class="indeed-company-info">
            <i class="bi bi-building"></i>
            <span>@Model.CompanyName</span>
            <span class="indeed-company-divider">•</span>
            <i class="bi bi-geo-alt"></i>
            <span>@Model.City, @Model.JobLocation</span>
        </div>
    </div>

    <!-- Questions Form Card -->
    <form method="post" action="@Url.Action("UpdateScreenerQuestions", "JobApplication", new { applicationUid = Model.ApplicationUid, returnToReview = ViewContext.HttpContext.Request.Query["returnToReview"].FirstOrDefault()?.ToLower() == "true" })">
        @Html.AntiForgeryToken()     
        <div class="job-card">
            <!-- Progress Bar -->
            <div class="indeed-progress-container">
                <div class="progress-bar-container">
                    <div class="progress-bar" id="progress-bar" style="width: 75%;"></div>
                </div>
            </div>

            <h2 class="indeed-section-title">
                <i class="bi bi-question-circle"></i>
                Answer these questions from the employer
            </h2>
            
            <div class="indeed-info-message">
                <i class="bi bi-shield-check"></i>
                <span>These are employer-written questions. Your responses will help the employer get to know you better.</span>
            </div>

            <div class="indeed-questions-container">
                <!-- Personal Information Section -->
                <div class="indeed-questions-section">
                    <h3 class="indeed-questions-section-title">
                        <i class="bi bi-person-badge"></i>
                        Personal Information
                    </h3>

                    <!-- Full Name -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            What's your legal full name? <span class="indeed-required">*</span>
                        </label>
                        <input type="text" name="ApplicantFullName" value="@Model.ApplicantFullName" class="indeed-form-input" 
                               placeholder="e.g. John Smith">
                        <div class="indeed-form-hint">Enter your full legal name as per official documents</div>
                    </div>

                    <!-- Email -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            What's your active email address? <span class="indeed-required">*</span>
                        </label>
                        <input type="email" name="ApplicantEmail" value="@Model.ApplicantEmail" class="indeed-form-input" 
                               placeholder="e.g. john.smith@email.com">
                        <div class="indeed-form-hint">We'll send application updates to this email</div>
                    </div>

                    <!-- Phone Number -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            What's your active contact number? <span class="indeed-required">*</span>
                        </label>
                        <input type="tel" id="phone" name="ApplicantMobileNumber" value="@Model.ApplicantMobileNumber" 
                               class="indeed-form-input" placeholder="Enter 10 digit number" 
                               pattern="[0-9]{10}" maxlength="10">
                        <div class="indeed-form-hint">Employer may contact you on this number</div>
                    </div>
                </div>

                <!-- Location Section -->
                <div class="indeed-questions-section">
                    <h3 class="indeed-questions-section-title">
                        <i class="bi bi-geo-alt"></i>
                        Location Details
                    </h3>

                    <!-- State Dropdown -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            What's your current Location? (State) <span class="indeed-required">*</span>
                        </label>
                        <select id="job_location" name="ApplicantJobLocation" class="indeed-form-select">
                            <option disabled selected="@(string.IsNullOrEmpty(Model?.ApplicantJobLocation) ? "selected" : null)">-- Select State --</option>
                            @foreach (var state in ViewBag.States as string[])
                            {
                                <option value="@state">@state</option>
                            }
                        </select>
                    </div>

                    <!-- City Dropdown -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            What's your current Town? (City) <span class="indeed-required">*</span>
                        </label>
                        <select id="city" name="ApplicantCity" class="indeed-form-select">
                            <option value="" selected disabled>-- Select City --</option>
                        </select>
                    </div>

                    <!-- Area Dropdown -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            What's your current neighborhood? (Area) <span class="indeed-required">*</span>
                        </label>
                        <select id="area" name="ApplicantArea" class="indeed-form-select">
                            <option value="" selected disabled>-- Select Area --</option>
                        </select>
                    </div>
                </div>

                <!-- Salary & Experience Section -->
                <div class="indeed-questions-section">
                    <h3 class="indeed-questions-section-title">
                        <i class="bi bi-cash-stack"></i>
                        Salary & Experience
                    </h3>

                    <!-- Current Monthly Salary -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            What's your current monthly salary? <span class="indeed-required">*</span>
                        </label>
                        <div class="indeed-salary-input-group">
                            <span class="indeed-currency-symbol">₹</span>
                            <input type="text" name="CurrentSalary" value="@Model.CurrentSalary" class="indeed-form-input indeed-salary-input" 
                                   placeholder="e.g. 25000" pattern="[0-9]+">
                        </div>
                        <div class="indeed-form-hint">Enter numbers only, no commas (e.g. 25000)</div>
                    </div>

                    <!-- Expected Monthly Salary -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            What's your expected monthly salary? <span class="indeed-required">*</span>
                        </label>
                        <div class="indeed-salary-input-group">
                            <span class="indeed-currency-symbol">₹</span>
                            <input type="text" name="ExpectedSalary" value="@Model.ExpectedSalary" class="indeed-form-input indeed-salary-input" 
                                   placeholder="e.g. 35000" pattern="[0-9]+">
                        </div>
                        <div class="indeed-form-hint">Enter numbers only, no commas (e.g. 35000)</div>
                    </div>

                    <!-- Years of Experience -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            How many years of experience do you have? <span class="indeed-required">*</span>
                        </label>
                        <input type="number" name="TotalExperience" value="@Model.TotalExperience" class="indeed-form-input" 
                               placeholder="e.g. 3" min="0" step="1">
                        <div class="indeed-form-hint">Enter total years of work experience</div>
                    </div>

                    <!-- Language Experience 1 -->
                 
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            How many years of experience do you have in @Model.Skills ? <span class="indeed-required">*</span>
                        </label>
                        <input type="number" 
                            name="SkillsExperience" 
                            value="@Model.SkillsExperience" 
                            class="indeed-form-input" 
                            placeholder="e.g. 2" min="0" step="1">
                    </div>
                  

                    @* <!-- Language Experience 2 -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            How many years of experience do you have in Hindi? <span class="indeed-required">*</span>
                        </label>
                        <input type="number" name="language_experience2" value="" class="indeed-form-input" 
                               placeholder="e.g. 5" min="0" step="1">
                    </div> *@
                </div>

                <!-- Education & Preferences Section -->
                <div class="indeed-questions-section">
                    <h3 class="indeed-questions-section-title">
                      <svg xmlns="http://www.w3.org/2000/svg" class="gap-2" width="20" height="20" fill="#0a66c2" class="bi bi-mortarboard-fill" viewBox="0 0 16 16">
                      <path d="M8.211 2.047a.5.5 0 0 0-.422 0l-7.5 3.5a.5.5 0 0 0 .025.917l7.5 3a.5.5 0 0 0 .372 0L14 7.14V13a1 1 0 0 0-1 1v2h3v-2a1 1 0 0 0-1-1V6.739l.686-.275a.5.5 0 0 0 .025-.917z"/>
                      <path d="M4.176 9.032a.5.5 0 0 0-.656.327l-.5 1.7a.5.5 0 0 0 .294.605l4.5 1.8a.5.5 0 0 0 .372 0l4.5-1.8a.5.5 0 0 0 .294-.605l-.5-1.7a.5.5 0 0 0-.656-.327L8 10.466z"/>
                      </svg>
                        Education & Preferences
                    </h3>

                    <!-- Education Level -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            What's the highest level of education you have completed? <span class="indeed-required">*</span>
                        </label>
                        <select id="education-level" name="ApplicantEducation" class="indeed-form-select">
                            <option value="" disabled selected="@(string.IsNullOrEmpty(Model?.ApplicantEducation) ? "selected" : null)">-- Select Education --</option>
                             @foreach (var edu in ViewBag.Education as string[])
                             {
                                <option value="@edu">@edu</option>
                             }
                        </select>
                    </div>

                    <!-- Relocation Question -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            Are you located in City? <span class="indeed-required">*</span>
                        </label>
                        <div class="indeed-radio-group">
                            <label class="indeed-radio-label">
                                <input type="radio" name="Relocation" value="yes" class="indeed-radio-input" @(Model.Relocation == true ? "checked=\"checked\"" : "")>
                                <span>Yes, I'm currently in City</span>
                            </label>
                            <label class="indeed-radio-label">
                                <input type="radio" name="Relocation" value="no" class="indeed-radio-input" @(!Model.Relocation == false ? "checked=\"checked\"" : "")>
                                <span>No, but I'm willing to relocate</span>
                            </label>
                        </div>
                    </div>

                    <!-- Notice Period -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            Are you on a notice period? <span class="indeed-required">*</span>
                        </label>
                            <select id="notice-period" name="NoticePeriod" class="indeed-form-select">
                                <option selected disabled>-- Select Notice Period --</option>
                                @foreach (NoticePeriod notice in Enum.GetValues(typeof(NoticePeriod)))
                                {
                                    var displayName = notice
                                        .GetType()
                                        .GetMember(notice.ToString())
                                        .First()
                                        .GetCustomAttribute<DisplayAttribute>()?.Name ?? notice.ToString();
                                    
                                    <option value="@notice" @(Model.NoticePeriod == notice ? "selected" : "")>
                                        @displayName 
                                    </option>
                                }
                            </select>
                    </div>

                    <!-- Interview Availability -->
                    <div class="indeed-form-group">
                        <label class="indeed-form-label">
                            Please list 2-3 dates and times you could do an interview <span class="indeed-required">*</span>
                        </label>
                        <textarea id="interview-availability" name="InterviewDates" 
                                  rows="4" class="indeed-form-textarea" 
                                  placeholder="e.g.&#10;Monday, March 10th - 10:00 AM to 12:00 PM&#10;Wednesday, March 12th - 2:00 PM to 4:00 PM&#10;Friday, March 14th - 3:00 PM to 5:00 PM">
                                  @Model.InterviewDates
                        </textarea>
                        <div class="indeed-form-hint">Provide at least 2-3 options for interview scheduling</div>
                    </div>
                </div>
            </div>

            <!-- Continue Button -->
            <div class="indeed-button-container">
                <button type="submit" class="indeed-btn-primary">
                    Continue
                </button>
            </div>

            <!-- Save for later option -->
            <div class="indeed-skip-option">
                <a href="@Url.Action("Retrieve", "IndeedClone")" class="indeed-skip-link">Save and come back later</a>
            </div>

        </div>
    </form>
</div>

</body>


<script>
   
    const savedState = "@Model?.ApplicantJobLocation";
    const savedCity  = "@Model?.ApplicantCity";
    const savedArea  = "@Model?.ApplicantArea";

    const states = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.States));
    const cities = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Cities));
    const areas  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Areas));

   const stateDropdown=document.getElementById("job_location"),cityDropdown=document.getElementById("city"),areaDropdown=document.getElementById("area");function populateCities(){const e=states.indexOf(stateDropdown.value);cityDropdown.innerHTML="<option selected disabled>-- Select City --</option>",areaDropdown.innerHTML="<option selected disabled>-- Select Area --</option>",-1!==e&&(cities[e].forEach((e=>{const t=document.createElement("option");t.value=e,t.textContent=e,cityDropdown.appendChild(t)})),savedCity&&(cityDropdown.value=savedCity,populateAreas()))}function populateAreas(){const e=states.indexOf(stateDropdown.value),t=cities[e].indexOf(cityDropdown.value);areaDropdown.innerHTML="<option selected disabled>-- Select Area --</option>",-1!==e&&-1!==t&&areas[e][t].forEach((e=>{const t=document.createElement("option");t.value=e,t.textContent=e,e===savedArea&&(t.selected=!0),areaDropdown.appendChild(t)}))}stateDropdown.addEventListener("change",populateCities),cityDropdown.addEventListener("change",populateAreas),savedState&&(stateDropdown.value=savedState,populateCities());

</script>

</html>