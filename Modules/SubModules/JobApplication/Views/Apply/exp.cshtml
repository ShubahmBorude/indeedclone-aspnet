@model IndeedClone.Modules.SubModules.JobApplication.DTO.RelExperienceDTO
@{
    Layout = "_JobApplicationNavbarLayout";
    ViewData["Title"] = " Relative Experience - IndeedClone";

 }


<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0">

    <link rel="icon" type="image/png" href="~/new/IndeedClone.png">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap-5 and custom CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- custom css -->
    <link rel="stylesheet" href="~/css/job-application/exp.css">
    <link rel="stylesheet" href="~/css/errors/error.css" />    

    <!-- Google Fonts Script -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Google+Sans&family=Roboto&family=Noto+Sans+Myanmar+UI&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

    <!-- Indeed Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indeed+Sans:wght@400;700&family=Noto+Sans:wght@400;700&family=Helvetica+Neue:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    @* <style> body{ padding : 0 !important;  margin: 0 !important; } </style> *@
</head>

<body>


<!-- Flash Messages -->
<div class="flash-messages-container">
    @if (TempData["Success"] != null)
    {
         <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                    <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                     <span>@Html.Raw(TempData["Success"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
     }

    @if (TempData["Error"] != null)
    {
         <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <div class="flash-content">
                <svg class="flash-icon" viewBox="0 0 24 24" width="20" height="20">
                     <path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                </svg>
                      <span>@Html.Raw(TempData["Error"])</span>
            </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
         </div>
     }
</div>

<!-- Main Content -->
<div class="container">
    <!-- Job Title Card - Indeed Style (like CV view) -->
    <div class="indeed-job-header-card">
        <h1 class="indeed-job-title">@Model.JobTitle</h1>
        <div class="indeed-company-info">
            <i class="bi bi-building"></i>
            <span>@Model.CompanyName</span>
            <span class="indeed-company-divider">•</span>
            <i class="bi bi-geo-alt"></i>
            <span>@Model.City, @Model.JobLocation</span>
        </div>
    </div>

    <!-- Add Experience Card -->
    <form method="post" action="@Url.Action("UpdateRelevenExperience", "JobApplication", new { applicationUid = Model.ApplicationUid, returnToReview = ViewContext.HttpContext.Request.Query["returnToReview"].FirstOrDefault()?.ToLower() == "true" })">
        @Html.AntiForgeryToken()
        <div class="job-card">
            <h2 class="indeed-section-title">
                <i class="bi bi-briefcase"></i>
                Enter a past job that shows relevant experience
            </h2>
            
            <div class="indeed-info-message">
                <i class="bi bi-info-circle"></i>
                <span>If you are a fresher, enter "Fresher" in both fields</span>
            </div>
            
            <div class="indeed-experience-card">
                <!-- job title -->
                <div class="indeed-form-group">
                    <label for="job-title" class="indeed-form-label">Job Title</label>
                    <input type="text" class="indeed-form-input" id="job-title" 
                           name="PreviousJobTitle" 
                           value="@Model.PreviousJobTitle"
                           placeholder="e.g. Software Developer, Sales Associate">
                    <div class="indeed-form-hint">Enter your most recent or current job title</div>
                </div>

                <!-- Company Name Input -->
                <div class="indeed-form-group">
                    <label for="company" class="indeed-form-label">Company Name</label>
                    <input type="text" class="indeed-form-input" id="company" 
                           name="PreviousCompanyName" 
                           value="@Model.PreviousCompanyName"
                           placeholder="e.g. Google, Amazon, Local Business">
                    <div class="indeed-form-hint">Where did/do you work?</div>
                </div>
            </div>

            <!-- Continue Button -->
            <div class="continue-button-container mb-3">
                <button type="submit" class="continue-button">Continue</button>
            </div>

            <!-- Skip option (like Indeed) -->
            <div class="indeed-skip-option">
                <a href="@Url.Action("Retrieve", "IndeedClone")" class="indeed-skip-link">Skip for now</a>
            </div>
        </div>
    </form>
</div>


</body>
</html>

